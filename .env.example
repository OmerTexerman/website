# PostHog analytics (optional — leave empty to disable tracking)
# Use https://us.i.posthog.com (US) or https://eu.i.posthog.com (EU) — both are allowlisted in vercel.json CSP.
# Custom API hosts require updating Content-Security-Policy in vercel.json.
PUBLIC_POSTHOG_KEY=
PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# Canonical site origin — used by Astro and meta tags
PUBLIC_SITE_ORIGIN=https://omer.texerman.com

# Cloudinary (used by /api/cloudinary-sign for signed image uploads)
# Find these at: https://console.cloudinary.com/settings/api-keys
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
