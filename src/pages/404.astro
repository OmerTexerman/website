---
import ContentHeader from "../components/ContentHeader.astro";
import ContextBackLink from "../components/ContextBackLink.astro";
import { site } from "../config";
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout title={`404 — Not Found | ${site.name}`} noindex>
  <ContentHeader />
  <main id="page-content" class="content-page-main flex items-center justify-center px-4 sm:px-6">
    <div class="content-surface text-center px-6 py-10 sm:px-10 sm:py-12 max-w-xl w-full">
      <h1 class="font-display text-6xl sm:text-8xl font-bold text-accent mb-4">404</h1>
      <p class="text-cream-dark text-lg mb-8">This page doesn't exist. Maybe it fell off the desk.</p>
      <ContextBackLink variant="button" />
    </div>
  </main>
</BaseLayout>
