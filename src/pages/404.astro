---
import ContentHeader from "../components/ContentHeader.astro";
import { site } from "../config";
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout title={`404 — Not Found | ${site.name}`}>
  <ContentHeader />
  <main id="page-content" class="pt-14 min-h-screen flex items-center justify-center content-page-bg px-4 sm:px-6">
    <div class="content-surface text-center px-6 py-10 sm:px-12 sm:py-16 max-w-xl w-full">
      <div class="mb-6 text-muted">
        <svg class="w-16 h-16 sm:w-20 sm:h-20 mx-auto opacity-40" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1">
          <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 14.25v-2.625a3.375 3.375 0 00-3.375-3.375h-1.5A1.125 1.125 0 0113.5 7.125v-1.5a3.375 3.375 0 00-3.375-3.375H8.25m2.25 0H5.625c-.621 0-1.125.504-1.125 1.125v17.25c0 .621.504 1.125 1.125 1.125h12.75c.621 0 1.125-.504 1.125-1.125V11.25a9 9 0 00-9-9z" />
          <path stroke-linecap="round" stroke-linejoin="round" d="M9 15l2 2 4-4" opacity="0" />
          <path stroke-linecap="round" stroke-linejoin="round" d="M9.75 14.25l1.5 1.5 3-3" opacity="0" />
        </svg>
      </div>
      <h1 class="font-display text-6xl sm:text-8xl font-bold text-accent mb-3">404</h1>
      <p class="text-cream-dark text-lg mb-2">This page doesn't exist.</p>
      <p class="text-muted text-sm mb-8">Maybe it fell off the desk.</p>
      <a
        href="/"
        class="inline-flex items-center gap-2 px-6 py-3 bg-accent text-white font-mono text-sm rounded-full hover:bg-accent-hover transition-colors shadow-lg shadow-accent/20"
      >
        <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7" />
        </svg>
        Back to desk
      </a>
    </div>
  </main>
</BaseLayout>
