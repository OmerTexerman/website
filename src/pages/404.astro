---
import ContentHeader from "../components/ContentHeader.astro";
import { site } from "../config";
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout title={`404 — Not Found | ${site.name}`}>
  <ContentHeader />
  <main id="page-content" class="content-page-bg flex min-h-screen items-center justify-center px-4 pt-14 sm:px-6">
    <div class="content-shell w-full max-w-2xl">
      <div class="content-surface px-6 py-10 text-center sm:px-10 sm:py-14">
        <p class="page-kicker mx-auto mb-5 w-fit">Desk view / lost item</p>
        <h1 class="font-display text-6xl font-bold text-accent sm:text-8xl">404</h1>
        <p class="mx-auto mt-4 max-w-lg text-lg text-cream-dark">This page doesn't exist. Maybe it slid behind the monitor or got tucked between the books.</p>
        <div class="mt-8 flex justify-center">
          <a href="/" class="desk-link">
            <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7" />
            </svg>
            Back to desk
          </a>
        </div>
      </div>
    </div>
  </main>
</BaseLayout>
