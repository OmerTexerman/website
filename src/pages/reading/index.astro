---
import { getCollection } from "astro:content";
import Bookshelf from "../../components/Bookshelf.astro";
import PageIntro from "../../components/PageIntro.astro";
import { navItems, site } from "../../config";
import ContentPage from "../../layouts/ContentPage.astro";

const nav = navItems.find((n) => n.href === "/reading");
const allBooks = await getCollection("books");

const toBookProps = (b: (typeof allBooks)[number]) => ({
	id: b.id,
	title: b.data.title,
	author: b.data.author,
	spineColor: b.data.spineColor,
	textColor: b.data.textColor,
	coverImage: b.data.coverImage,
	review: b.data.review,
	rating: b.data.rating,
	pageCount: b.data.pageCount,
	url: b.data.url,
});

const reading = allBooks.filter((b) => b.data.status === "reading").map(toBookProps);
const finished = allBooks.filter((b) => b.data.status === "finished").map(toBookProps);
const wantToRead = allBooks.filter((b) => b.data.status === "want-to-read").map(toBookProps);

const sections = [
	{ title: "Currently Reading", books: reading },
	{ title: "Finished", books: finished },
	{ title: "Want to Read", books: wantToRead },
].filter((s) => s.books.length > 0);
---

<ContentPage title={`Reading | ${site.name}`} description={nav?.description}>
  <PageIntro title="Reading" description={nav?.description} />

  {sections.map((section, si) => (
    <div class={si > 0 ? "mt-10" : ""} data-animate style={`transition-delay: ${si * 0.15}s`}>
      <Bookshelf books={section.books} sectionTitle={section.title} />
    </div>
  ))}
</ContentPage>
