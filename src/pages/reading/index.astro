---
import ContentPage from "../../layouts/ContentPage.astro";
import BookCard from "../../components/BookCard.astro";
import { getCollection } from "astro:content";
import { site, navItems } from "../../config";

const nav = navItems.find((n) => n.href === "/reading");
const allBooks = await getCollection("books");

const reading = allBooks.filter((b) => b.data.status === "reading");
const finished = allBooks.filter((b) => b.data.status === "finished");
const wantToRead = allBooks.filter((b) => b.data.status === "want-to-read");

const sections = [
  { title: "Currently Reading", books: reading },
  { title: "Finished", books: finished },
  { title: "Want to Read", books: wantToRead },
].filter((s) => s.books.length > 0);
---

<ContentPage title={`Reading | ${site.name}`} description={nav?.description}>
  <div class="mb-10" data-animate>
    <h1 class="font-display text-4xl sm:text-5xl font-bold tracking-tight mb-3 text-dark">Reading</h1>
    {nav?.description && <p class="text-muted text-lg">{nav.description}</p>}
  </div>

  {sections.map((section, si) => (
    <div class={si > 0 ? "mt-10" : ""} data-animate style={`transition-delay: ${si * 0.15}s`}>
      <h2 class="font-display text-2xl font-bold mb-4 text-dark">{section.title}</h2>
      <div class="space-y-3">
        {section.books.map((book) => (
          <BookCard
            title={book.data.title}
            author={book.data.author}
            spineColor={book.data.spineColor}
            url={book.data.url}
          />
        ))}
      </div>
    </div>
  ))}
</ContentPage>
