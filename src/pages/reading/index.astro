---
import BookCard from "../../components/BookCard.astro";
import { getSectionById } from "../../config";
import { getReadingSections } from "../../content/selectors";
import ContentPage from "../../layouts/ContentPage.astro";

const section = getSectionById("reading");
const readingSections = await getReadingSections();
---

<ContentPage section={section}>
  {readingSections.length === 0 ? (
    <p class="text-muted font-mono">nothing here yet :)</p>
  ) : (
    readingSections.map((readingSection, si) => (
      <div class={si > 0 ? "mt-10" : ""} data-animate style={`transition-delay: ${si * 0.15}s`}>
        <h2 class="font-display text-2xl font-bold mb-4 text-cream">{readingSection.title}</h2>
        <div class="space-y-3">
          {readingSection.books.map((book) => (
            <BookCard
              title={book.data.title}
              author={book.data.author}
              spineColor={book.data.spineColor}
              url={book.data.url}
              post={book.data.post}
            />
          ))}
        </div>
      </div>
    ))
  )}
</ContentPage>
