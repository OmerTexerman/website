---
import PhotoCollectionCard from "../../components/PhotoCollectionCard.astro";
import { getSectionById } from "../../config";
import { getPhotoCollections } from "../../content/selectors";
import ContentPage from "../../layouts/ContentPage.astro";

const section = getSectionById("photos");
const collections = await getPhotoCollections();
---

<ContentPage section={section}>
  {collections.length === 0 ? (
    <p class="text-muted font-mono">nothing here yet :)</p>
  ) : (
    <div class="photo-collections-grid" data-animate style="transition-delay: 0.15s">
      {collections.map((collection, i) => (
        <div class:list={[i === 0 && collections.length > 1 ? "photo-collection-hero" : ""]}>
          <PhotoCollectionCard collection={collection} featured={i === 0 && collections.length > 1} />
        </div>
      ))}
    </div>
  )}
</ContentPage>
