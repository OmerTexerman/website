---
import ContentPage from "../../layouts/ContentPage.astro";
import PhotoGallery from "../../components/PhotoGallery.astro";
import { getCollection } from "astro:content";

const photos = (await getCollection("photos")).map((p) => p.data);
---

<ContentPage title="Photos | Omer Texerman" description="Lorem ipsum dolor sit amet.">
  <div class="mb-10" data-animate>
    <h1 class="font-display text-4xl sm:text-5xl font-bold tracking-tight mb-3 text-dark">Photos</h1>
    <p class="text-muted text-lg">Lorem ipsum dolor sit amet, consectetur adipiscing elit.</p>
  </div>

  <div data-animate style="transition-delay: 0.15s">
    <PhotoGallery photos={photos} />
  </div>
</ContentPage>
