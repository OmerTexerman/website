---
import "../../styles/photos.css";
import PhotoGallery from "../../components/PhotoGallery.astro";
import RelatedPost from "../../components/RelatedPost.astro";
import { getPhotoCollections } from "../../content/selectors";
import ContentShell from "../../layouts/ContentShell.astro";

export async function getStaticPaths() {
	const collections = await getPhotoCollections();
	return collections.map((collection) => ({
		params: { slug: collection.id },
		props: { collection },
	}));
}

const { collection } = Astro.props;
---

<ContentShell
  title={`${collection.title} | Photos`}
  description={collection.description}
  containerWidthClass="max-w-6xl"
  surface={false}
>
  {/* Header as a pinned note card */}
  <div class="collection-header" data-animate>
    <div class="collection-header-pin" aria-hidden="true"></div>
    <a
      href="/photos"
      class="collection-back-link"
    >
      <svg class="h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
        <path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7" />
      </svg>
      All photos
    </a>

    <h1 class="collection-header-title">
      {collection.title}
    </h1>

    <div class="collection-header-meta">
      {collection.location && <span>{collection.location}</span>}
      {collection.location && collection.date && <span>/</span>}
      {collection.date && <span>{collection.date}</span>}
      <span>/</span>
      <span>{collection.photos.length} photos</span>
    </div>

    {collection.description && (
      <p class="collection-header-desc">{collection.description}</p>
    )}

    {collection.post && <RelatedPost slug={collection.post} class="mt-3" />}
  </div>

  {/* Photos as pinned prints on the board */}
  <div class="corkboard-gallery" data-animate style="transition-delay: 0.15s">
    <PhotoGallery photos={collection.photos} />
  </div>
</ContentShell>
