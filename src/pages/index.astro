---
import BaseLayout from "../layouts/BaseLayout.astro";
import ContentModal from "../components/ContentModal.astro";
import SceneCanvas from "../components/SceneCanvas.astro";
import { site, navItems } from "../config";
---

<BaseLayout
  title={`${site.name} | ${site.title}`}
  description={site.description}
  fullscreen
>
  <div class="fixed inset-0 h-dvh min-h-screen overflow-hidden bg-dark">
    <div id="scene-fallback" aria-hidden="true" class="absolute inset-0 z-10 flex items-end sm:items-center justify-center px-4 py-8 sm:px-6 pointer-events-none">
      <div class="max-w-xl rounded-2xl border border-white/10 bg-dark-surface/90 p-6 sm:p-8 shadow-2xl backdrop-blur-md">
        <p class="font-mono text-xs uppercase tracking-[0.3em] text-accent mb-3">Portfolio</p>
        <h1 class="font-display text-4xl sm:text-5xl font-bold tracking-tight text-cream mb-4">
          {site.name}
        </h1>
        <p class="text-cream-dark text-base sm:text-lg leading-relaxed mb-6">{site.description}</p>
        <div class="flex flex-wrap gap-3">
          {navItems.map(({ href, label }) => (
            <a
              href={href}
              data-fallback-link
              tabindex="-1"
              class="inline-flex items-center rounded-full border border-white/10 px-4 py-2 font-mono text-sm text-cream transition-colors hover:border-accent/50 hover:text-accent"
            >
              {label}
            </a>
          ))}
        </div>
      </div>
    </div>
    <SceneCanvas />
    <ContentModal />

    <!-- Accessibility: skip to nav + hidden text nav -->
    <a
      href="#text-nav"
      class="sr-only focus:not-sr-only focus:absolute focus:top-4 focus:left-4 focus:z-50 focus:bg-dark-surface focus:text-cream focus:px-4 focus:py-2 focus:rounded-lg focus:border focus:border-white/20 focus:font-mono focus:text-sm"
    >
      Skip to navigation
    </a>
    <nav id="text-nav" tabindex="-1" class="sr-only focus-within:not-sr-only focus-within:absolute focus-within:bottom-8 focus-within:left-1/2 focus-within:-translate-x-1/2 focus-within:z-50 focus-within:bg-dark-surface/95 focus-within:backdrop-blur-sm focus-within:rounded-xl focus-within:border focus-within:border-white/10 focus-within:p-4" aria-label="Site navigation">
      <ul class="flex gap-6 font-mono text-sm">
        {navItems.map(({ href, label }) => (
          <li><a href={href} class="text-cream hover:text-accent transition-colors">{label}</a></li>
        ))}
      </ul>
    </nav>
  </div>

  <noscript>
    <style>
      #scene-fallback {
        opacity: 1;
        pointer-events: auto;
      }
    </style>
  </noscript>

  <!-- Unified scene boot -->
  <script>
    let sceneHandle: { cleanup: () => void; transition: (target: "desktop" | "mobile") => Promise<void> } | null = null;
    let activeMode: "desktop" | "mobile" | null = null;
    let transitionQueue: Promise<void> = Promise.resolve();
    const fallback = document.getElementById("scene-fallback");
    const fallbackLinks = [...document.querySelectorAll<HTMLAnchorElement>("[data-fallback-link]")];

    function setFallbackInteractive(visible: boolean) {
      if (!fallback) return;
      fallback.setAttribute("aria-hidden", visible ? "false" : "true");
      for (const link of fallbackLinks) {
        if (visible) link.removeAttribute("tabindex");
        else link.setAttribute("tabindex", "-1");
      }
    }

    let fallbackTimer = window.setTimeout(() => {
      if (!sceneHandle) {
        document.documentElement.dataset.sceneFallback = "visible";
        setFallbackInteractive(true);
      }
    }, 900);

    function modeFromWidth(): "desktop" | "mobile" {
      return window.innerWidth >= 768 ? "desktop" : "mobile";
    }

    async function applyMode(mode: "desktop" | "mobile") {
      if (!sceneHandle) {
        const root = document.getElementById("scene-root")!;
        const canvas = document.getElementById("scene-canvas") as HTMLCanvasElement;
        const labels = document.getElementById("scene-labels") as HTMLElement;
        const booksJson = root.getAttribute("data-books");
        const books = booksJson ? JSON.parse(booksJson) : undefined;

        const { initUnifiedScene } = await import("../three/unified-scene");
        sceneHandle = initUnifiedScene(canvas, labels, mode, books);
        (window as any).__sceneHandle = sceneHandle;
        window.clearTimeout(fallbackTimer);
        delete document.documentElement.dataset.sceneFallback;
        setFallbackInteractive(false);
        document.documentElement.dataset.sceneReady = "true";
        activeMode = mode;
        return;
      }

      if (mode === activeMode) return;

      await sceneHandle.transition(mode);
      activeMode = mode;
    }

    function queueModeSync() {
      transitionQueue = transitionQueue
        .then(() => applyMode(modeFromWidth()))
        .catch((error) => {
          console.error("Failed to update scene mode", error);
        });
    }

    function cleanup() {
      if (sceneHandle) {
        sceneHandle.cleanup();
        sceneHandle = null;
      }
      activeMode = null;
      delete (window as any).__sceneHandle;
      window.clearTimeout(fallbackTimer);
      fallbackTimer = 0;
      delete document.documentElement.dataset.sceneFallback;
      setFallbackInteractive(false);
      delete document.documentElement.dataset.sceneReady;
      mql.removeEventListener("change", onMediaChange);
    }

    function onMediaChange() {
      queueModeSync();
    }

    document.addEventListener("astro:before-preparation", cleanup, { once: true });
    window.addEventListener("beforeunload", cleanup, { once: true });

    const mql = window.matchMedia("(min-width: 768px)");
    mql.addEventListener("change", onMediaChange);
    queueModeSync();
  </script>
</BaseLayout>
