---
import BaseLayout from "../layouts/BaseLayout.astro";
import ContentModal from "../components/ContentModal.astro";
import SceneCanvas from "../components/SceneCanvas.astro";
import { site, navItems } from "../config";
---

<BaseLayout
  title={`${site.name} | ${site.title}`}
  description={site.description}
  fullscreen
>
  <div class="fixed inset-0 h-dvh min-h-screen overflow-hidden bg-dark">
    <SceneCanvas />
    <ContentModal />

    <!-- Accessibility: skip to nav + hidden text nav -->
    <a
      href="#text-nav"
      class="sr-only focus:not-sr-only focus:absolute focus:top-4 focus:left-4 focus:z-50 focus:bg-dark-surface focus:text-cream focus:px-4 focus:py-2 focus:rounded-lg focus:border focus:border-white/20 focus:font-mono focus:text-sm"
    >
      Skip to navigation
    </a>
    <nav id="text-nav" class="sr-only focus-within:not-sr-only focus-within:absolute focus-within:bottom-8 focus-within:left-1/2 focus-within:-translate-x-1/2 focus-within:z-50 focus-within:bg-dark-surface/95 focus-within:backdrop-blur-sm focus-within:rounded-xl focus-within:border focus-within:border-white/10 focus-within:p-4" aria-label="Site navigation">
      <ul class="flex gap-6 font-mono text-sm">
        {navItems.map(({ href, label }) => (
          <li><a href={href} class="text-cream hover:text-accent transition-colors">{label}</a></li>
        ))}
      </ul>
    </nav>
  </div>

  <!-- Unified scene boot -->
  <script>
    let sceneHandle: {
      cleanup: () => void;
      transition: (target: "desktop" | "mobile") => Promise<void>;
      resize: () => void;
    } | null = null;
    let activeMode: "desktop" | "mobile" | null = null;
    let transitionQueue: Promise<void> = Promise.resolve();

    function modeFromWidth(): "desktop" | "mobile" {
      return window.innerWidth >= 768 ? "desktop" : "mobile";
    }

    async function applyMode(mode: "desktop" | "mobile") {
      if (!sceneHandle) {
        const root = document.getElementById("scene-root")!;
        const canvas = document.getElementById("scene-canvas") as HTMLCanvasElement;
        const labels = document.getElementById("scene-labels") as HTMLElement;
        const booksJson = root.getAttribute("data-books");
        const books = booksJson ? JSON.parse(booksJson) : undefined;

        const { initUnifiedScene } = await import("../three/unified-scene");
        sceneHandle = initUnifiedScene(canvas, labels, mode, books);
        (window as any).__sceneHandle = sceneHandle;
        activeMode = mode;
        return;
      }

      if (mode === activeMode) return;

      await sceneHandle.transition(mode);
      activeMode = mode;
    }

    function queueModeSync() {
      transitionQueue = transitionQueue
        .then(() => applyMode(modeFromWidth()))
        .catch((error) => {
          console.error("Failed to update scene mode", error);
        });
    }

    function cleanup() {
      if (sceneHandle) {
        sceneHandle.cleanup();
        sceneHandle = null;
      }
      activeMode = null;
      window.removeEventListener("resize", onResize);
      window.visualViewport?.removeEventListener("resize", onResize);
      mql.removeEventListener("change", onMediaChange);
    }

    function onMediaChange() {
      queueModeSync();
    }

    let resizeRaf = 0;
    function onResize() {
      if (resizeRaf) cancelAnimationFrame(resizeRaf);
      resizeRaf = requestAnimationFrame(() => {
        resizeRaf = 0;
        sceneHandle?.resize();
        queueModeSync();
      });
    }

    document.addEventListener("astro:before-preparation", cleanup, { once: true });
    window.addEventListener("beforeunload", cleanup, { once: true });

    const mql = window.matchMedia("(min-width: 768px)");
    mql.addEventListener("change", onMediaChange);
    window.addEventListener("resize", onResize, { passive: true });
    window.visualViewport?.addEventListener("resize", onResize, { passive: true });
    queueModeSync();
  </script>
</BaseLayout>
