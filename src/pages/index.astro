---
import "../styles/blog.css";
import "../styles/phone.css";
import "../styles/photos.css";
import "../styles/projects.css";
import "../styles/reading.css";
import "../styles/spotlight.css";
import "../styles/wotd.css";
import ContentModal from "../components/ContentModal.astro";
import SceneCanvas from "../components/SceneCanvas.astro";
import { orderedSections, site } from "../config";
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout
  title={`${site.name} | ${site.title}`}
  description={site.description}
  fullscreen
>
  <main class="fixed inset-0 h-dvh min-h-screen overflow-hidden bg-dark">
    <div id="scene-fallback" class="absolute inset-0 z-10 flex items-end sm:items-center justify-center px-4 py-8 sm:px-6 pointer-events-none">
      <div class="max-w-xl rounded-2xl border border-white/10 bg-dark-surface/90 p-6 sm:p-8 shadow-2xl backdrop-blur-md">
        <p class="font-mono text-xs uppercase tracking-[0.3em] text-accent mb-3">Portfolio</p>
        <h1 class="font-display text-4xl sm:text-5xl font-bold tracking-tight text-cream mb-4">
          {site.name}
        </h1>
        <p class="text-cream-dark text-base sm:text-lg leading-relaxed mb-6">{site.description}</p>
        <div class="flex flex-wrap gap-3">
          {orderedSections.map(({ href, label }) => (
            <a href={href} class="nav-pill-link">{label}</a>
          ))}
        </div>
      </div>
    </div>
    <!-- Accessibility: skip to nav + hidden text nav (before canvas so skip link is reachable) -->
    <a
      href="#text-nav"
      class="skip-link"
    >
      Skip to navigation
    </a>
    <nav id="text-nav" tabindex="-1" class="sr-only focus-within:not-sr-only focus-within:absolute focus-within:bottom-8 focus-within:left-1/2 focus-within:-translate-x-1/2 focus-within:z-50 focus-within:bg-dark-surface/95 focus-within:backdrop-blur-sm focus-within:rounded-xl focus-within:border focus-within:border-white/10 focus-within:p-4" aria-label="Site navigation">
      <ul class="flex gap-6 font-mono text-sm">
        {orderedSections.map(({ href, label }) => (
          <li><a href={href} class="text-cream hover:text-accent transition-colors">{label}</a></li>
        ))}
      </ul>
    </nav>
    <SceneCanvas />
    <ContentModal />
  </main>

  <noscript>
    <style>
      #scene-fallback {
        opacity: 1;
        pointer-events: auto;
      }
    </style>
  </noscript>

  <!-- Unified scene boot -->
  <script>
    import { mountSceneApp } from "../dom/scene-app";
    import { bootstrapContentModal } from "../modal/bootstrap";

    let cleanup = mountSceneApp();
    const listenerAc = new AbortController();

    // Re-mount after bfcache restore.  The pagehide cleanup disposed GPU
    // resources but left the context alive for bfcache.  mountSceneApp
    // handles context-lost detection internally; we still need to
    // re-bootstrap the modal here.
    window.addEventListener("pageshow", (e) => {
      if (!e.persisted) return;
      cleanup();
      cleanup = mountSceneApp();
      bootstrapContentModal();
    }, { signal: listenerAc.signal });

    // Clean up listener on bfcache storage or page unload
    window.addEventListener("pagehide", () => listenerAc.abort(), { once: true });

    if (import.meta.hot) {
      import.meta.hot.dispose(() => {
        cleanup();
        listenerAc.abort();
      });
    }
  </script>
</BaseLayout>
