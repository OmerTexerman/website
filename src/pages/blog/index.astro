---
import BlogCard from "../../components/BlogCard.astro";
import { getSectionById } from "../../config";
import { getPublishedPosts } from "../../content/selectors";
import ContentPage from "../../layouts/ContentPage.astro";

const section = getSectionById("blog");
const posts = await getPublishedPosts();
---

<ContentPage section={section}>
  {posts.length === 0 ? (
    <p class="text-muted font-mono">nothing here yet :)</p>
  ) : (
    <div class="space-y-5">
      {posts.map((post, i) => (
        <div data-animate style={`transition-delay: ${i * 0.1}s`}>
          <BlogCard
            title={post.data.title}
            description={post.data.description}
            pubDate={post.data.pubDate}
            tags={post.data.tags}
            slug={post.id}
          />
        </div>
      ))}
    </div>
  )}
</ContentPage>
