---
import ContentPage from "../../layouts/ContentPage.astro";
import BlogCard from "../../components/BlogCard.astro";
import { site, navItems } from "../../config";
import { getPublishedPosts } from "../../utils";

const nav = navItems.find((n) => n.href === "/blog");
const posts = await getPublishedPosts();
---

<ContentPage title={`Blog | ${site.name}`} description={nav?.description}>
  <div class="mb-10" data-animate>
    <h1 class="font-display text-4xl sm:text-5xl font-bold tracking-tight mb-3 text-cream">Blog</h1>
    {nav?.description && <p class="text-cream-dark text-lg">{nav.description}</p>}
  </div>

  {posts.length === 0 ? (
    <p class="text-muted font-mono">No posts yet. Check back soon!</p>
  ) : (
    <div class="space-y-5">
      {posts.map((post, i) => (
        <div data-animate style={`transition-delay: ${i * 0.1}s`}>
          <BlogCard
            title={post.data.title}
            description={post.data.description}
            pubDate={post.data.pubDate}
            tags={post.data.tags}
            slug={post.id}
          />
        </div>
      ))}
    </div>
  )}
</ContentPage>
