---
import BlogCard from "../../components/BlogCard.astro";
import { getSectionById } from "../../config";
import { getPublishedPosts } from "../../content/selectors";
import ContentPage from "../../layouts/ContentPage.astro";

const section = getSectionById("blog");
const posts = await getPublishedPosts();
---

<ContentPage section={section} surface={false} containerWidthClass="max-w-3xl" showIntro={false}>
  <div class="notebook-page" data-animate>
    <div class="notebook-cover-edge"></div>
    <div class="notebook-paper">
      {/* Title written on the notebook page */}
      <h1 class="notebook-page-title">Blog</h1>

      {posts.length === 0 ? (
        <p class="notebook-empty-text">nothing here yet :)</p>
      ) : (
        <>
          <input type="search" class="content-search" placeholder="search entries..." data-content-search />
          <div class="notebook-entries" data-content-list>
            {posts.map((post, i) => (
              <div data-animate style={`transition-delay: ${i * 0.1}s`}>
                <BlogCard
                  title={post.data.title}
                  description={post.data.description}
                  pubDate={post.data.pubDate}
                  tags={post.data.tags}
                  slug={post.id}
                />
              </div>
            ))}
          </div>
          <p class="content-no-results" data-content-no-results>No matching entries.</p>
          <button class="show-more-btn" data-show-more>Show more</button>
        </>
      )}
    </div>
  </div>

  <script>
    import { mountContentList } from "../../dom/content-list";

    const container = document.querySelector<HTMLElement>("[data-content-list]");
    const searchInput = document.querySelector<HTMLInputElement>("[data-content-search]");
    const showMoreBtn = document.querySelector<HTMLElement>("[data-show-more]");
    const noResults = document.querySelector<HTMLElement>("[data-content-no-results]");

    if (container) {
      mountContentList({ container, searchInput, showMoreButton: showMoreBtn, noResultsEl: noResults });
    }
  </script>
</ContentPage>
