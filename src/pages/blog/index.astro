---
import BlogCard from "../../components/BlogCard.astro";
import PageIntro from "../../components/PageIntro.astro";
import Tag from "../../components/Tag.astro";
import { navItems, site } from "../../config";
import ContentPage from "../../layouts/ContentPage.astro";
import { formatDate, getPublishedPosts } from "../../utils";

const nav = navItems.find((n) => n.href === "/blog");
const posts = await getPublishedPosts();
const featured = posts.find((p) => p.data.featured);
const rest = posts.filter((p) => p !== featured);
---

<ContentPage title={`Blog | ${site.name}`} description={nav?.description}>
  <PageIntro title="Blog" description={nav?.description} />

  {posts.length === 0 ? (
    <div class="text-center py-12">
      <p class="text-muted font-mono text-sm">No posts yet. Check back soon!</p>
    </div>
  ) : (
    <div>
      {featured && (
        <a
          href={`/blog/${featured.id}`}
          class="group block mb-8 rounded-xl border border-white/8 bg-dark-surface-elevated overflow-hidden transition-[transform,box-shadow] duration-200 hover:ring-2 hover:ring-accent/40 hover:translate-y-[-2px] focus:outline-none focus:ring-2 focus:ring-accent"
          data-animate
        >
          <div class="p-5 sm:p-8">
            <div class="flex items-center gap-3 mb-4">
              <div class="w-2 h-2 rounded-full bg-accent animate-pulse"></div>
              <span class="font-mono text-xs uppercase tracking-[0.15em] text-accent">Featured</span>
              <span class="font-mono text-xs text-muted">{formatDate(featured.data.pubDate)}</span>
            </div>
            <h2 class="font-display text-2xl sm:text-3xl font-bold text-cream group-hover:text-accent transition-colors mb-3 tracking-tight">
              {featured.data.title}
            </h2>
            <p class="text-cream-dark text-base leading-relaxed mb-4 max-w-2xl">{featured.data.description}</p>
            {featured.data.tags && featured.data.tags.length > 0 && (
              <div class="flex flex-wrap gap-2">
                {featured.data.tags.map((tag) => (
                  <Tag label={tag} />
                ))}
              </div>
            )}
            <span class="inline-flex items-center gap-1.5 mt-5 font-mono text-sm text-accent group-hover:text-accent-hover transition-colors">
              Read more
              <svg class="w-4 h-4 transition-transform group-hover:translate-x-1" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" />
              </svg>
            </span>
          </div>
        </a>
      )}

      {rest.length > 0 && (
        <div>
          {featured && (
            <div class="flex items-center gap-3 mb-5" data-animate style="transition-delay: 0.1s">
              <span class="font-mono text-xs uppercase tracking-wider text-muted">All Posts</span>
              <div class="flex-1 h-px bg-white/8"></div>
            </div>
          )}
          <div class="space-y-4">
            {rest.map((post, i) => (
              <div data-animate style={`transition-delay: ${(i + (featured ? 2 : 1)) * 0.1}s`}>
                <BlogCard
                  title={post.data.title}
                  description={post.data.description}
                  pubDate={post.data.pubDate}
                  tags={post.data.tags}
                  slug={post.id}
                />
              </div>
            ))}
          </div>
        </div>
      )}
    </div>
  )}
</ContentPage>
