---
import ContentPage from "../../layouts/ContentPage.astro";
import BlogCard from "../../components/BlogCard.astro";
import { getCollection } from "astro:content";

const posts = (await getCollection("blog"))
  .filter((post) => !post.data.draft)
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
---

<ContentPage title="Blog | Omer Texerman" description="Lorem ipsum dolor sit amet, consectetur adipiscing elit.">
  <div class="mb-10" data-animate>
    <h1 class="font-display text-4xl sm:text-5xl font-bold tracking-tight mb-3 text-dark">Blog</h1>
    <p class="text-muted text-lg">Lorem ipsum dolor sit amet, consectetur adipiscing elit.</p>
  </div>

  {posts.length === 0 ? (
    <p class="text-muted font-mono">No posts yet. Check back soon!</p>
  ) : (
    <div class="space-y-5">
      {posts.map((post, i) => (
        <div data-animate style={`transition-delay: ${i * 0.1}s`}>
          <BlogCard
            title={post.data.title}
            description={post.data.description}
            pubDate={post.data.pubDate}
            tags={post.data.tags}
            slug={post.id}
          />
        </div>
      ))}
    </div>
  )}
</ContentPage>
