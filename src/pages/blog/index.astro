---
import BaseLayout from "../../layouts/BaseLayout.astro";
import BlogCard from "../../components/BlogCard.astro";
import { getCollection } from "astro:content";

const posts = (await getCollection("blog"))
  .filter((post) => !post.data.draft)
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
---

<BaseLayout title="Blog | Portfolio">
  <section class="max-w-3xl mx-auto px-6 py-32">
    <h1 class="text-4xl font-bold tracking-tight mb-4">Blog</h1>
    <p class="text-zinc-400 mb-12">Thoughts on development, technology, and things I'm learning.</p>

    {posts.length === 0 ? (
      <p class="text-zinc-500">No posts yet. Check back soon!</p>
    ) : (
      <div class="space-y-6">
        {posts.map((post) => (
          <BlogCard
            title={post.data.title}
            description={post.data.description}
            pubDate={post.data.pubDate}
            tags={post.data.tags}
            slug={post.id}
          />
        ))}
      </div>
    )}
  </section>
</BaseLayout>
