---
import BaseLayout from "../../layouts/BaseLayout.astro";
import BlogCard from "../../components/BlogCard.astro";
import { getCollection } from "astro:content";

const posts = (await getCollection("blog"))
  .filter((post) => !post.data.draft)
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
---

<BaseLayout title="Blog | Omer Texerman">
  <section class="max-w-4xl mx-auto px-6 pt-32 pb-24">
    <div class="mb-12" data-animate>
      <h1 class="font-display text-5xl font-extrabold tracking-tight mb-4">Blog</h1>
      <p class="text-muted text-lg">Thoughts on development, technology, and things I'm learning.</p>
    </div>

    {posts.length === 0 ? (
      <p class="text-muted font-mono">No posts yet. Check back soon!</p>
    ) : (
      <div class="space-y-6">
        {posts.map((post, i) => (
          <div data-animate style={`transition-delay: ${i * 0.1}s`}>
            <BlogCard
              title={post.data.title}
              description={post.data.description}
              pubDate={post.data.pubDate}
              tags={post.data.tags}
              slug={post.id}
            />
          </div>
        ))}
      </div>
    )}
  </section>
</BaseLayout>
