---
import "../../styles/phone.css";
import { getSectionById } from "../../config";
import { getOrderedProjects, getSetup } from "../../content/selectors";
import ContentPage from "../../layouts/ContentPage.astro";

const section = getSectionById("projects");
const projects = await getOrderedProjects();
const setupCategories = await getSetup();

// Fake delivery ages for the notification metaphor — newest project first
const notifAges = ["now", "2m", "1h", "3h", "1d", "3d", "1w"];
---

<ContentPage section={section} surface={false} containerWidthClass="max-w-lg" showIntro={false}>
  <h1 class="sr-only">Projects</h1>
  <div class="phone-body" data-animate>
    {/* Status bar */}
    <div class="phone-status-bar">
      <span class="phone-carrier">{"OT&T"}</span>
      <span class="phone-camera-dot" aria-hidden="true"></span>
      <div class="phone-status-icons">
        <span class="phone-signal-bars" aria-hidden="true">
          <span></span><span></span><span></span><span></span>
        </span>
        <span class="phone-battery-pill">
          <span class="phone-battery-fill"></span>
        </span>
      </div>
    </div>

    {/* Lock-screen clock — static 9:41 for the scriptless modal preview */}
    <div class="phone-lock-header">
      <time class="phone-clock" id="phone-clock">9:41</time>
      <p class="phone-date" id="phone-date"></p>
    </div>

    {/* Content area — widget under the clock, notifications rise from the bottom */}
    <div class="phone-screen">
      {/* Setup as a lock-screen widget */}
      {setupCategories.length > 0 && (
        <section class="phone-widget" style="animation-delay: 0.1s">
          <div class="phone-widget-head">
            <span class="phone-widget-icon" aria-hidden="true"></span>
            <span>Setup</span>
          </div>
          <div class="phone-widget-grid">
            {setupCategories.map((cat) => (
              <div class="phone-widget-cell">
                <span class="phone-widget-label">{cat.name}</span>
                {cat.items.map((item) => (
                  <span class="phone-widget-value">
                    {item.name}{item.detail ? ` — ${item.detail}` : ""}
                  </span>
                ))}
              </div>
            ))}
          </div>
        </section>
      )}

      {/* Projects as a bottom-anchored notification stack */}
      <div class="phone-feed">
        {projects.map((project, i) => (
          <article class="phone-notif" style={`animation-delay: ${0.15 + i * 0.08}s`}>
            <div class="phone-notif-head">
              <span class="phone-notif-icon" aria-hidden="true">{project.data.title.charAt(0)}</span>
              <span class="phone-notif-app">{project.data.tech.join(", ")}</span>
              <span class="phone-notif-age">{notifAges[i] ?? "1w+"}</span>
            </div>
            <h2 class="phone-notif-title">{project.data.title}</h2>
            <p class="phone-notif-desc">{project.data.description}</p>
            {(project.data.url || project.data.repo) && (
              <div class="phone-notif-actions">
                {project.data.url && (
                  <a class="phone-chip" href={project.data.url} target="_blank" rel="noopener noreferrer" aria-label={`Open ${project.data.title}`}>open</a>
                )}
                {project.data.repo && (
                  <a class="phone-chip" href={project.data.repo} target="_blank" rel="noopener noreferrer" aria-label={`View source: ${project.data.title}`}>src</a>
                )}
              </div>
            )}
          </article>
        ))}

        {projects.length === 0 && (
          <div class="phone-empty">no new notifications :)</div>
        )}
      </div>
    </div>

    {/* Bottom bar */}
    <div class="phone-bottom-bar">
      <div class="phone-bottom-pill"></div>
    </div>
  </div>
</ContentPage>

<script>
  function updatePhoneClock() {
    const now = new Date();
    const clockEl = document.getElementById("phone-clock");
    if (clockEl) {
      clockEl.textContent = now.toLocaleTimeString("en-US", { hour: "numeric", minute: "2-digit" });
      clockEl.setAttribute("datetime", now.toISOString());
    }
    const dateEl = document.getElementById("phone-date");
    if (dateEl) {
      dateEl.textContent = now.toLocaleDateString("en-US", {
        weekday: "long",
        month: "long",
        day: "numeric",
      });
    }
  }
  updatePhoneClock();
  const phoneClockId = setInterval(updatePhoneClock, 10_000);

  function clearPhoneTimers() {
    clearInterval(phoneClockId);
  }
  document.addEventListener("astro:before-preparation", clearPhoneTimers, { once: true });
  window.addEventListener("pagehide", clearPhoneTimers, { once: true });
</script>
