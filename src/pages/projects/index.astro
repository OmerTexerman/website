---
import { getCollection } from "astro:content";
import PageIntro from "../../components/PageIntro.astro";
import ProjectCard from "../../components/ProjectCard.astro";
import { navItems, site } from "../../config";
import ContentPage from "../../layouts/ContentPage.astro";

const nav = navItems.find((n) => n.href === "/projects");
const projects = (await getCollection("projects")).sort((a, b) => a.data.order - b.data.order);
const allPosts = await getCollection("blog");

// Resolve related posts for each project
const projectsWithRelated = projects.map((project) => {
	const relatedPosts = (project.data.relatedPosts || [])
		.map((slug) => {
			const post = allPosts.find((p) => p.id === slug);
			if (!post) return null;
			return { slug: post.id, title: post.data.title, description: post.data.description };
		})
		.filter(Boolean) as { slug: string; title: string; description: string }[];

	return { project, relatedPosts };
});
---

<ContentPage title={`Projects | ${site.name}`} description={nav?.description}>
  <PageIntro title="Projects" description={nav?.description} />

  {projectsWithRelated.length === 0 ? (
    <div class="text-center py-12">
      <p class="text-muted font-mono text-sm">No projects yet. Check back soon!</p>
    </div>
  ) : (
    <div class="space-y-5">
      {projectsWithRelated.map(({ project, relatedPosts }, i) => (
        <div data-animate style={`transition-delay: ${i * 0.1}s`}>
          <ProjectCard
            title={project.data.title}
            description={project.data.description}
            tech={project.data.tech}
            url={project.data.url}
            repo={project.data.repo}
            image={project.data.image}
            relatedPosts={relatedPosts}
          />
        </div>
      ))}
    </div>
  )}
</ContentPage>
