---
import { getCollection } from "astro:content";
import PageIntro from "../../components/PageIntro.astro";
import ProjectCard from "../../components/ProjectCard.astro";
import { navItems, site } from "../../config";
import ContentPage from "../../layouts/ContentPage.astro";
import { getPublishedPosts } from "../../utils";

const nav = navItems.find((n) => n.href === "/projects");
const projects = (await getCollection("projects")).sort((a, b) => a.data.order - b.data.order);
const posts = await getPublishedPosts();
const postsBySlug = new Map(posts.map((post) => [post.id, post.data.title]));
---

<ContentPage title={`Projects | ${site.name}`} description={nav?.description}>
  <PageIntro title="Projects" description={nav?.description} />

  {projects.length === 0 ? (
    <p class="font-mono text-muted">No projects yet. Check back soon!</p>
  ) : (
    <div class="object-stack">
      {projects.map((project, i) => (
        <div class="object-row" data-animate style={`transition-delay: ${i * 0.08}s`}>
          <ProjectCard
            title={project.data.title}
            description={project.data.description}
            tech={project.data.tech}
            folder={project.data.folder}
            notes={project.data.notes}
            relatedPosts={project.data.relatedPosts.map((slug) => ({ slug, title: postsBySlug.get(slug) ?? slug }))}
            url={project.data.url}
            repo={project.data.repo}
          />
        </div>
      ))}
    </div>
  )}
</ContentPage>
