---
import ContentPage from "../../layouts/ContentPage.astro";
import ProjectCard from "../../components/ProjectCard.astro";
import { getCollection } from "astro:content";
import { site, navItems } from "../../config";

const nav = navItems.find((n) => n.href === "/projects");
const projects = (await getCollection("projects"))
  .sort((a, b) => a.data.order - b.data.order);
---

<ContentPage title={`Projects | ${site.name}`} description={nav?.description}>
  <div class="mb-10" data-animate>
    <h1 class="font-display text-4xl sm:text-5xl font-bold tracking-tight mb-3 text-cream">Projects</h1>
    {nav?.description && <p class="text-cream-dark text-lg">{nav.description}</p>}
  </div>

  {projects.length === 0 ? (
    <p class="text-muted font-mono">No projects yet. Check back soon!</p>
  ) : (
    <div class="space-y-5">
      {projects.map((project, i) => (
        <div data-animate style={`transition-delay: ${i * 0.1}s`}>
          <ProjectCard
            title={project.data.title}
            description={project.data.description}
            tech={project.data.tech}
            url={project.data.url}
            repo={project.data.repo}
          />
        </div>
      ))}
    </div>
  )}
</ContentPage>
