---
import BaseLayout from "./BaseLayout.astro";
import ContentHeader from "../components/ContentHeader.astro";
import BackToDesk from "../components/BackToDesk.astro";
import Footer from "../components/Footer.astro";

interface Props {
  title: string;
  description?: string;
  image?: string;
  type?: "website" | "article";
  publishedDate?: Date;
}

const { title, description, image, type, publishedDate } = Astro.props;
---

<BaseLayout
  title={title}
  description={description}
  image={image}
  type={type}
  publishedDate={publishedDate}
>
  <ContentHeader />
  <main class="pt-14 min-h-screen bg-[radial-gradient(circle_at_top,_rgba(196,69,58,0.12),_transparent_28%),linear-gradient(180deg,_#201f1e_0%,_#171716_100%)]">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 py-8 sm:py-16">
      <div class="content-surface p-5 sm:p-8 md:p-12">
        <slot />
      </div>
    </div>
  </main>
  <Footer />
  <BackToDesk />
</BaseLayout>
