---
import PageIntro from "../components/PageIntro.astro";
import type { SiteSection } from "../config";
import { getSectionPageTitle } from "../config";
import ContentShell from "./ContentShell.astro";

interface Props {
	section: SiteSection;
}

const { section } = Astro.props;
---

<ContentShell
  title={getSectionPageTitle(section)}
  description={section.description}
>
  <PageIntro title={section.label} description={section.description} />
  <slot />
</ContentShell>
