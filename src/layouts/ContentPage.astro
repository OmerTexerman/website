---
import PageIntro from "../components/PageIntro.astro";
import type { SiteSection } from "../config";
import { getSectionPageTitle } from "../config";
import ContentShell from "./ContentShell.astro";

interface Props {
	section: SiteSection;
	surface?: boolean;
	containerWidthClass?: string;
	showIntro?: boolean;
}

const { section, surface, containerWidthClass, showIntro = true } = Astro.props;
---

<ContentShell
  title={getSectionPageTitle(section)}
  description={section.description}
  surface={surface}
  containerWidthClass={containerWidthClass}
>
  {showIntro && <PageIntro title={section.label} description={section.description} />}
  <slot />
</ContentShell>
