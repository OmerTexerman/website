---
import "../styles/global.css";
import SEOHead from "../components/SEOHead.astro";
import { analytics, blogFeed, getRootThemeStyle, site } from "../config";

interface Props {
	title: string;
	description?: string;
	image?: string;
	type?: "website" | "article";
	publishedDate?: Date;
	/** When true, hides header/footer (used for homepage 3D scene) */
	fullscreen?: boolean;
}

const {
	title,
	description = site.title,
	image,
	type = "website",
	publishedDate,
	fullscreen = false,
} = Astro.props;

const posthogKey = analytics.posthogKey;
const posthogHost = analytics.posthogHost;
const rootThemeStyle = getRootThemeStyle();
---

<!doctype html>
<html lang="en" style={rootThemeStyle}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="sitemap" href="/sitemap-index.xml" />
    <link rel="alternate" type="application/rss+xml" title={blogFeed.title} href="/rss.xml" />
    <link rel="manifest" href="/site.webmanifest" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:ital,opsz,wght@0,14..32,400;0,14..32,500;0,14..32,600;1,14..32,400&family=JetBrains+Mono:wght@400;500&family=Space+Grotesk:wght@400;500;600;700&display=swap"
      rel="stylesheet"
    />
    <SEOHead
      title={title}
      description={description}
      image={image}
      type={type}
      publishedDate={publishedDate}
    />
    <title>{title}</title>
  </head>
  <body
    class={fullscreen ? "overflow-hidden h-dvh" : "min-h-screen"}
    data-posthog-key={posthogKey || undefined}
    data-posthog-host={posthogHost || undefined}
  >
    {!fullscreen && (
      <a
        href="#page-content"
        class="skip-link"
      >
        Skip to content
      </a>
    )}

    <slot />

    {!fullscreen && (
      <script>
        import { mountContextBackLinks } from "../dom/context-back-link";
        import { mountRevealAnimations } from "../dom/page-effects";

        mountContextBackLinks();
        const cleanupReveal = mountRevealAnimations();
        document.addEventListener("astro:before-preparation", cleanupReveal, { once: true });
      </script>
    )}

    {posthogKey && (
      <script>
        import { mountPosthogAnalytics } from "../dom/page-effects";

        mountPosthogAnalytics();
      </script>
    )}
  </body>
</html>
