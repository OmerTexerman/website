---
import ContextBackLink from "../components/ContextBackLink.astro";
import Tag from "../components/Tag.astro";
import { getSectionById, site } from "../config";
import { formatDate } from "../utils";
import ContentShell from "./ContentShell.astro";

interface Props {
	title: string;
	description: string;
	pubDate: Date;
	updatedDate?: Date;
	tags?: string[];
}

const { title, description, pubDate, updatedDate, tags } = Astro.props;
const blogSection = getSectionById("blog");
---

<ContentShell
  title={`${title} | ${site.name}`}
  description={description}
  type="article"
  publishedDate={pubDate}
  containerTag="article"
  containerWidthClass="max-w-3xl"
  showBackLink={false}
>
  <ContextBackLink
    fallbackHref={blogSection.href}
    fallbackLabel={blogSection.backLabel}
    variant="inline"
  />

  <header class="mb-10">
    <time datetime={pubDate.toISOString()} class="font-mono text-sm text-muted">
      {formatDate(pubDate, "long")}
    </time>
    {updatedDate && (
      <span class="font-mono text-sm text-muted ml-3">
        (Updated {formatDate(updatedDate, "long")})
      </span>
    )}
    <h1 class="font-display text-4xl sm:text-5xl font-bold mt-3 mb-4 tracking-tight text-cream">
      {title}
    </h1>
    <p class="text-lg text-cream-dark">{description}</p>
    {tags && tags.length > 0 && (
      <div class="flex flex-wrap gap-2 mt-4">
        {tags.map((tag) => (
          <Tag label={tag} />
        ))}
      </div>
    )}
  </header>

  <div class="blog-prose">
    <slot />
  </div>
</ContentShell>
