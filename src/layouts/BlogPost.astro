---
import BackToDesk from "../components/BackToDesk.astro";
import ContentHeader from "../components/ContentHeader.astro";
import Footer from "../components/Footer.astro";
import Tag from "../components/Tag.astro";
import { site } from "../config";
import { formatDate } from "../utils";
import BaseLayout from "./BaseLayout.astro";

interface Props {
	title: string;
	description: string;
	pubDate: Date;
	updatedDate?: Date;
	tags?: string[];
}

const { title, description, pubDate, updatedDate, tags } = Astro.props;
---

<BaseLayout
  title={`${title} | ${site.name}`}
  description={description}
  type="article"
  publishedDate={pubDate}
>
  <ContentHeader />
  <main id="page-content" class="content-page-bg min-h-screen pt-14">
    <article class="content-shell mx-auto max-w-5xl px-4 py-8 sm:px-6 sm:py-16">
      <div class="content-surface p-5 sm:p-8 md:p-12" data-preview-content>
        <a
          data-context-back-link
          href="/blog"
          class="desk-link mb-10"
          aria-label="Back to blog"
        >
          <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7" />
          </svg>
          <span data-context-back-label>Back to blog</span>
        </a>

        <header class="mb-10 border-b border-white/10 pb-8">
          <div class="mb-4 flex flex-wrap items-center gap-3 text-sm text-muted">
            <span class="page-kicker">Desk view / note</span>
            <time datetime={pubDate.toISOString()} class="font-mono text-xs uppercase tracking-[0.2em] text-muted-light">
              {formatDate(pubDate, "long")}
            </time>
            {updatedDate && (
              <span class="font-mono text-xs uppercase tracking-[0.2em] text-muted-light">
                Updated {formatDate(updatedDate, "long")}
              </span>
            )}
          </div>
          <h1 class="font-display text-4xl font-bold tracking-tight text-cream sm:text-5xl">
            {title}
          </h1>
          <p class="mt-4 max-w-3xl text-lg text-cream-dark">{description}</p>
          {tags && tags.length > 0 && (
            <div class="mt-5 flex flex-wrap gap-2">
              {tags.map((tag) => (
                <Tag label={tag} />
              ))}
            </div>
          )}
        </header>

        <div class="prose prose-invert prose-lg max-w-none prose-headings:font-display prose-headings:tracking-tight prose-headings:text-cream prose-p:text-cream-dark prose-strong:text-cream prose-li:text-cream-dark prose-blockquote:border-l-accent prose-blockquote:text-cream-dark prose-a:text-accent prose-a:underline-offset-2 hover:prose-a:text-accent-hover prose-code:text-accent prose-code:font-mono prose-pre:bg-dark prose-pre:text-cream prose-pre:rounded-xl prose-img:rounded-xl">
          <slot />
        </div>
      </div>
    </article>
  </main>
  <Footer />
  <BackToDesk />
</BaseLayout>
