---
import ContextBackLink from "../components/ContextBackLink.astro";
import { getSectionById, site } from "../config";
import { formatDate } from "../utils";
import ContentShell from "./ContentShell.astro";

interface Props {
	title: string;
	description: string;
	pubDate: Date;
	updatedDate?: Date;
	tags?: string[];
}

const { title, description, pubDate, updatedDate, tags } = Astro.props;
const blogSection = getSectionById("blog");
---

<ContentShell
  title={`${title} | ${site.name}`}
  description={description}
  type="article"
  publishedDate={pubDate}
  containerTag="article"
  containerWidthClass="max-w-3xl"
  showBackLink={false}
  surface={false}
>
  <div class="notebook-page" data-animate>
    <div class="notebook-cover-edge"></div>
    <div class="notebook-paper notebook-paper-post">
      <ContextBackLink
        fallbackHref={blogSection.href}
        fallbackLabel={blogSection.backLabel}
        variant="inline"
      />

      <header class="notebook-post-header">
        <time datetime={pubDate.toISOString()} class="notebook-entry-date">
          {formatDate(pubDate, "long")}
        </time>
        {updatedDate && (
          <span class="notebook-entry-date ml-3">
            (Updated {formatDate(updatedDate, "long")})
          </span>
        )}
        <h1 class="notebook-post-title">{title}</h1>
        <p class="notebook-post-desc">{description}</p>
        {tags && tags.length > 0 && (
          <span class="notebook-entry-tags">{tags.join(" · ")}</span>
        )}
      </header>

      <div class="blog-prose blog-prose-notebook">
        <slot />
      </div>
    </div>
  </div>
</ContentShell>
