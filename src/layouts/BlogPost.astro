---
import BaseLayout from "./BaseLayout.astro";
import ContentHeader from "../components/ContentHeader.astro";
import BackToDesk from "../components/BackToDesk.astro";
import Footer from "../components/Footer.astro";
import { site } from "../config";

interface Props {
  title: string;
  description: string;
  pubDate: Date;
  updatedDate?: Date;
  tags?: string[];
}

const { title, description, pubDate, updatedDate, tags } = Astro.props;

const formattedDate = pubDate.toLocaleDateString("en-US", {
  year: "numeric",
  month: "long",
  day: "numeric",
});

const formattedUpdatedDate = updatedDate?.toLocaleDateString("en-US", {
  year: "numeric",
  month: "long",
  day: "numeric",
});
---

<BaseLayout
  title={`${title} | ${site.name}`}
  description={description}
  type="article"
  publishedDate={pubDate}
>
  <ContentHeader />
  <main class="pt-14 min-h-screen">
    <article class="max-w-3xl mx-auto px-6 py-16">
      <div class="content-surface p-8 sm:p-12">
        <a
          href="/blog"
          class="inline-flex items-center gap-1.5 font-mono text-sm text-muted hover:text-dark transition-colors mb-10"
        >
          <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7" />
          </svg>
          Back to blog
        </a>

        <header class="mb-10">
          <time class="font-mono text-sm text-muted">{formattedDate}</time>
          {formattedUpdatedDate && (
            <span class="font-mono text-sm text-muted ml-3">
              (Updated {formattedUpdatedDate})
            </span>
          )}
          <h1 class="font-display text-4xl sm:text-5xl font-bold mt-3 mb-4 tracking-tight text-dark">
            {title}
          </h1>
          <p class="text-lg text-muted">{description}</p>
          {tags && tags.length > 0 && (
            <div class="flex flex-wrap gap-2 mt-4">
              {tags.map((tag) => (
                <span class="font-mono text-xs px-2.5 py-1 rounded-full bg-accent/10 text-accent border border-accent/20">
                  {tag}
                </span>
              ))}
            </div>
          )}
        </header>

        <div class="prose prose-lg max-w-none prose-headings:font-display prose-headings:tracking-tight prose-a:text-accent prose-a:underline-offset-2 hover:prose-a:text-accent-hover prose-code:text-accent prose-code:font-mono prose-pre:bg-dark prose-pre:text-cream prose-pre:rounded-xl prose-img:rounded-xl">
          <slot />
        </div>
      </div>
    </article>
  </main>
  <Footer />
  <BackToDesk />
</BaseLayout>
