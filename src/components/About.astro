---
const skills = [
  { name: "TypeScript", color: "bg-sky" },
  { name: "React", color: "bg-lavender" },
  { name: "Node.js", color: "bg-mint" },
  { name: "Go", color: "bg-yellow" },
  { name: "PostgreSQL", color: "bg-sky" },
  { name: "Docker", color: "bg-lavender" },
  { name: "AWS", color: "bg-mint" },
  { name: "Kubernetes", color: "bg-yellow" },
];
---

<section id="about" class="py-24 px-6">
  <div class="max-w-6xl mx-auto">
    <div class="flex items-start gap-6 mb-12" data-animate>
      <span class="font-display font-extrabold text-[8rem] leading-none section-number select-none hidden md:block">
        01
      </span>
      <div class="pt-6">
        <h2 class="font-display text-4xl font-bold">About</h2>
      </div>
    </div>

    <div class="grid md:grid-cols-2 gap-12 items-start">
      <div class="space-y-4 text-muted leading-relaxed text-lg" data-animate>
        <p>
          Write a few paragraphs about yourself here. Your background,
          what drives you, and what you're currently working on.
        </p>
        <p>
          Another paragraph about your interests, approach to development,
          or anything else you'd like visitors to know.
        </p>
      </div>
      <div class="grid grid-cols-2 gap-3">
        {skills.map((skill, i) => (
          <div
            data-animate
            style={`transition-delay: ${i * 0.06}s`}
            class={`${skill.color} border-2 border-ink rounded-lg p-4 font-mono text-sm font-bold text-ink hard-shadow-sm hard-shadow-hover cursor-default`}
          >
            {skill.name}
          </div>
        ))}
      </div>
    </div>
  </div>
</section>
