---
import { site, socials } from "../config";

const year = new Date().getFullYear();
const activeSocials = socials.filter((s) => s.url);
---

<footer class="border-t border-white/8 bg-dark">
  <div class="max-w-6xl mx-auto px-6 py-10">
    <div class="flex flex-col sm:flex-row items-center justify-between gap-6">
      <div class="flex items-center gap-3">
        <span class="inline-flex items-center justify-center w-8 h-8 bg-accent/10 text-accent font-display font-bold text-xs rounded-lg border border-accent/20">
          {site.initials}
        </span>
        <p class="font-mono text-sm text-muted">&copy; {year} {site.name}</p>
      </div>
      {activeSocials.length > 0 && (
        <div class="flex items-center gap-4">
          {activeSocials.map((social) => (
            <a
              href={social.url}
              target="_blank"
              rel="noopener noreferrer"
              class="w-9 h-9 flex items-center justify-center rounded-full border border-white/8 text-muted hover:text-cream hover:border-accent/40 transition-colors"
              aria-label={`${social.label} (opens in a new window)`}
            >
              <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24" set:html={social.icon} />
            </a>
          ))}
        </div>
      )}
    </div>
  </div>
</footer>
