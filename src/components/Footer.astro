---
import { Icon } from "astro-icon/components";
import { site, socials } from "../config";

const year = new Date().getFullYear();
const activeSocials = socials.filter((s) => s.url);
---

<footer class="border-t border-white/10 bg-dark">
  <div class="max-w-6xl mx-auto px-6 py-8 flex flex-col sm:flex-row items-center justify-between gap-4">
    <p class="font-mono text-sm text-muted">&copy; {year} {site.name}</p>
    {activeSocials.length > 0 && (
      <div class="flex items-center gap-5">
        {activeSocials.map((social) => (
          <a
            href={social.url}
            target="_blank"
            rel="noopener noreferrer"
            class="text-muted hover:text-cream transition-colors"
            aria-label={`${social.label} (opens in a new window)`}
          >
            <Icon name={social.icon} class="w-5 h-5" />
          </a>
        ))}
      </div>
    )}
  </div>
</footer>
