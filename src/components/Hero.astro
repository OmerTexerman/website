---

---

<section class="min-h-screen flex items-center justify-center px-6 pt-16 relative overflow-hidden">
  <div class="max-w-6xl mx-auto w-full">
    <div class="relative">
      <p class="font-mono text-sm text-coral border-l-2 border-coral pl-3 mb-8 animate-slide-up">
        Full Stack Developer
      </p>

      <h1 class="font-display font-extrabold tracking-tight leading-[0.85]">
        <span class="block text-[clamp(4rem,14vw,12rem)] animate-slide-up" style="animation-delay: 0.1s">
          OMER
        </span>
        <span class="block text-[clamp(4rem,14vw,12rem)] animate-slide-up" style="animation-delay: 0.2s">
          TEXERMAN
        </span>
      </h1>

      <!-- Decorative rotating star -->
      <div class="absolute top-4 right-0 md:right-16 text-coral select-none pointer-events-none animate-spin-slow">
        <svg width="80" height="80" viewBox="0 0 80 80" fill="currentColor">
          <path d="M40 0 L44 36 L80 40 L44 44 L40 80 L36 44 L0 40 L36 36 Z" />
        </svg>
      </div>

      <p class="text-muted text-lg max-w-md mt-8 leading-relaxed animate-fade-in" style="animation-delay: 0.4s">
        A brief description about yourself and what you do. Replace this with your own intro.
      </p>

      <div class="flex flex-wrap gap-4 mt-10 animate-fade-in" style="animation-delay: 0.55s">
        <a
          href="#projects"
          class="inline-flex items-center gap-2 px-6 py-3 bg-coral text-white font-mono text-sm font-bold rounded-lg border-2 border-ink hard-shadow hard-shadow-hover"
        >
          View Projects
          <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
          </svg>
        </a>
        <a
          href="/blog"
          class="inline-flex items-center gap-2 px-6 py-3 bg-cream text-ink font-mono text-sm font-bold rounded-lg border-2 border-ink hard-shadow hard-shadow-hover"
        >
          Read Blog
        </a>
      </div>
    </div>
  </div>

  <!-- Scroll indicator -->
  <div class="absolute bottom-8 left-1/2 -translate-x-1/2 animate-fade-in" style="animation-delay: 0.8s">
    <div class="w-7 h-11 rounded-full border-2 border-ink flex items-start justify-center p-2">
      <div class="w-1.5 h-1.5 rounded-full bg-ink animate-bounce" />
    </div>
  </div>
</section>
