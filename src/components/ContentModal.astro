---
/**
 * Shared content preview modal for the homepage scene.
 * Exposes window.__contentModal = { open, close, onClose } for Three.js scenes.
 */
---

<div
  id="content-modal"
  class="fixed inset-0 z-50 pointer-events-none opacity-0 transition-opacity duration-300"
  aria-hidden="true"
>
  <div id="content-modal-backdrop" class="absolute inset-0 bg-dark/80 backdrop-blur-sm"></div>
  <div
    id="content-modal-panel"
    class="absolute inset-x-4 bottom-0 top-16 sm:inset-x-auto sm:left-1/2 sm:-translate-x-1/2 sm:max-w-3xl sm:w-full translate-y-full transition-transform duration-500 ease-out"
    role="dialog"
    aria-modal="true"
    aria-labelledby="content-modal-title"
    tabindex="-1"
  >
    <div class="h-full rounded-t-2xl shadow-2xl overflow-hidden flex flex-col bg-dark-surface/95 border border-white/10 backdrop-blur-md">
      <div class="flex items-center justify-between px-6 py-4 border-b border-white/10">
        <h2 id="content-modal-title" class="font-display text-xl font-bold text-cream"></h2>
        <button id="content-modal-close" class="w-8 h-8 flex items-center justify-center rounded-full hover:bg-white/8 transition-colors text-muted-light hover:text-cream" aria-label="Close">
          <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
          </svg>
        </button>
      </div>
      <div id="content-modal-body" class="flex-1 overflow-y-auto p-6 text-cream" aria-live="polite">
        <div class="flex items-center justify-center py-12">
          <div class="w-6 h-6 border-2 border-accent border-t-transparent rounded-full animate-spin"></div>
        </div>
      </div>
      <div class="px-6 py-4 border-t border-white/10">
        <a id="content-modal-link" href="/" class="inline-flex items-center gap-2 font-mono text-sm text-accent hover:text-accent-hover transition-colors">
          View full page
          <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" />
          </svg>
        </a>
      </div>
    </div>
  </div>
</div>

<script>
  const existingCleanup = (window as any).__contentModalCleanup;
  if (typeof existingCleanup === "function") existingCleanup();

  const modal = document.getElementById("content-modal");
  const panel = document.getElementById("content-modal-panel");
  const title = document.getElementById("content-modal-title");
  const body = document.getElementById("content-modal-body");
  const link = document.getElementById("content-modal-link");
  const closeBtn = document.getElementById("content-modal-close");
  const backdrop = document.getElementById("content-modal-backdrop");

  const FOCUSABLE = 'a[href],button:not([disabled]),textarea:not([disabled]),input:not([disabled]),select:not([disabled]),[tabindex]:not([tabindex="-1"])';

  if (
    modal instanceof HTMLElement &&
    panel instanceof HTMLElement &&
    title instanceof HTMLElement &&
    body instanceof HTMLElement &&
    link instanceof HTMLAnchorElement &&
    closeBtn instanceof HTMLElement &&
    backdrop instanceof HTMLElement
  ) {
    const closeCallbacks = new Set<() => void>();
    const siblingStates = new Map<HTMLElement, { ariaHidden: string | null; inert: boolean }>();
    let previousActiveElement: HTMLElement | null = null;
    let isOpen = false;
    let activeRequest: AbortController | null = null;

    function renderLoading() {
      body.replaceChildren();
      const wrapper = document.createElement("div");
      wrapper.className = "flex items-center justify-center py-12";
      const spinner = document.createElement("div");
      spinner.className =
        "w-6 h-6 border-2 border-accent border-t-transparent rounded-full animate-spin";
      wrapper.append(spinner);
      body.append(wrapper);
    }

    function renderMessage(message: string, href: string) {
      body.replaceChildren();
      const paragraph = document.createElement("p");
      paragraph.className = "text-muted text-center py-8";
      paragraph.append(document.createTextNode(`${message} `));
      const anchor = document.createElement("a");
      anchor.href = href;
      anchor.className = "text-accent underline";
      anchor.textContent = "Visit the page";
      paragraph.append(anchor);
      body.append(paragraph);
    }

    function sanitizeNode(root: Element) {
      root
        .querySelectorAll("script,style,iframe,object,embed,form,link,meta,noscript")
        .forEach((el) => el.remove());
      root.querySelectorAll("*").forEach((el) => {
        for (const attr of [...el.attributes]) {
          const name = attr.name.toLowerCase();
          const value = attr.value.trim().toLowerCase();
          if (name.startsWith("on")) el.removeAttribute(attr.name);
          else if ((name === "href" || name === "src") && value.startsWith("javascript:")) {
            el.removeAttribute(attr.name);
          }
        }
      });
    }

    function syncSiblings(disabled: boolean) {
      for (const el of [...document.body.children]) {
        if (!(el instanceof HTMLElement) || el === modal) continue;

        if (disabled) {
          siblingStates.set(el, {
            ariaHidden: el.getAttribute("aria-hidden"),
            inert: el.inert,
          });
          el.setAttribute("aria-hidden", "true");
          el.inert = true;
        } else {
          const previous = siblingStates.get(el);
          if (!previous) continue;
          if (previous.ariaHidden === null) el.removeAttribute("aria-hidden");
          else el.setAttribute("aria-hidden", previous.ariaHidden);
          el.inert = previous.inert;
        }
      }

      if (!disabled) siblingStates.clear();
    }

    function trapFocus(e: KeyboardEvent) {
      if (e.key !== "Tab" || !isOpen) return;
      const focusable = [...panel.querySelectorAll<HTMLElement>(FOCUSABLE)].filter(
        (el) => !el.hasAttribute("disabled") && el.offsetParent !== null,
      );
      if (focusable.length === 0) {
        e.preventDefault();
        panel.focus();
        return;
      }
      const first = focusable[0];
      const last = focusable[focusable.length - 1];
      if (e.shiftKey && document.activeElement === first) {
        e.preventDefault();
        last.focus();
      } else if (!e.shiftKey && document.activeElement === last) {
        e.preventDefault();
        first.focus();
      }
    }

    function openModal(label: string, href: string) {
      previousActiveElement =
        document.activeElement instanceof HTMLElement ? document.activeElement : null;
      title.textContent = label;
      link.href = href;
      renderLoading();

      modal.classList.remove("pointer-events-none", "opacity-0");
      modal.classList.add("pointer-events-auto", "opacity-100");
      modal.setAttribute("aria-hidden", "false");
      document.body.style.overflow = "hidden";
      syncSiblings(true);
      isOpen = true;

      requestAnimationFrame(() => {
        panel.classList.remove("translate-y-full");
        panel.classList.add("translate-y-0");
        closeBtn.focus();
      });

      activeRequest?.abort();
      activeRequest = new AbortController();

      const url = new URL(href, window.location.origin);
      if (url.origin !== window.location.origin) {
        renderMessage("External preview is blocked.", href);
        return;
      }

      fetch(url.toString(), { signal: activeRequest.signal })
        .then((r) => {
          if (!r.ok) throw new Error();
          return r.text();
        })
        .then((html) => {
          const doc = new DOMParser().parseFromString(html, "text/html");
          const content =
            doc.querySelector("[data-preview-content]") ||
            doc.querySelector(".content-surface") ||
            doc.querySelector("main");
          if (!content) {
            renderMessage("No content found.", href);
            return;
          }

          const sanitized = content.cloneNode(true) as Element;
          sanitizeNode(sanitized);
          body.replaceChildren(...Array.from(sanitized.childNodes));
          body.querySelectorAll("[data-animate]").forEach((el) => el.classList.add("is-visible"));
        })
        .catch((err: unknown) => {
          if (err instanceof DOMException && err.name === "AbortError") return;
          renderMessage("Could not load preview.", href);
        });
    }

    function closeModal() {
      if (!isOpen) return;
      activeRequest?.abort();
      activeRequest = null;
      panel.classList.remove("translate-y-0");
      panel.classList.add("translate-y-full");
      isOpen = false;
      document.body.style.overflow = "";
      syncSiblings(false);
      for (const cb of closeCallbacks) cb();
      window.setTimeout(() => {
        modal.classList.remove("pointer-events-auto", "opacity-100");
        modal.classList.add("pointer-events-none", "opacity-0");
        modal.setAttribute("aria-hidden", "true");
        previousActiveElement?.focus();
        previousActiveElement = null;
      }, 300);
    }

    function onClose(cb: () => void): () => void {
      closeCallbacks.add(cb);
      return () => {
        closeCallbacks.delete(cb);
      };
    }

    function onKeydown(e: KeyboardEvent) {
      if (e.key === "Escape") closeModal();
      trapFocus(e);
    }

    function cleanup() {
      activeRequest?.abort();
      activeRequest = null;
      syncSiblings(false);
      closeCallbacks.clear();
      closeBtn.removeEventListener("click", closeModal);
      backdrop.removeEventListener("click", closeModal);
      document.removeEventListener("keydown", onKeydown);
      document.removeEventListener("astro:before-preparation", cleanup);
      delete (window as any).__contentModal;
      delete (window as any).__contentModalCleanup;
    }

    closeBtn.addEventListener("click", closeModal);
    backdrop.addEventListener("click", closeModal);
    document.addEventListener("keydown", onKeydown);
    document.addEventListener("astro:before-preparation", cleanup, { once: true });

    (window as any).__contentModal = { open: openModal, close: closeModal, onClose };
    (window as any).__contentModalCleanup = cleanup;
  }
</script>
