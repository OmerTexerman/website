---
/**
 * Shared content preview modal for the homepage scene.
 */
---

<div
  id="content-modal"
  class="fixed inset-0 z-50 invisible pointer-events-none"
  aria-hidden="true"
>
  <div id="content-modal-backdrop" class="absolute inset-0 bg-dark/80 backdrop-blur-sm opacity-0"></div>
  <div
    id="content-modal-panel"
    class="absolute bottom-0 left-4 right-4 top-16 will-change-transform [backface-visibility:hidden] sm:left-0 sm:right-0 sm:mx-auto sm:w-[calc(100%-2rem)] sm:max-w-3xl"
    style="opacity: 0; translate: 0 88px;"
    role="dialog"
    aria-modal="true"
    aria-labelledby="content-modal-title"
  >
    <div
      id="content-modal-surface"
      class="flex h-full flex-col overflow-hidden rounded-t-2xl border border-white/10 bg-dark-surface/95 shadow-2xl isolate [contain:paint]"
    >
      <div class="flex items-center justify-between border-b border-white/10 px-6 py-4">
        <h2 id="content-modal-title" class="font-display text-xl font-bold text-cream"></h2>
        <button
          id="content-modal-close"
          class="flex h-8 w-8 items-center justify-center rounded-full text-muted-light transition-colors hover:bg-white/8 hover:text-cream"
          aria-label="Close"
          type="button"
        >
          <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
          </svg>
        </button>
      </div>
      <div
        id="content-modal-body"
        class="min-h-0 flex-1 overflow-y-auto overscroll-contain p-6 text-cream"
        aria-live="polite"
      >
        <div class="flex items-center justify-center py-12">
          <div class="h-6 w-6 animate-spin rounded-full border-2 border-accent border-t-transparent"></div>
        </div>
      </div>
      <div class="border-t border-white/10 px-6 py-4">
        <a
          id="content-modal-link"
          href="/"
          class="inline-flex items-center gap-2 font-mono text-sm text-accent transition-colors hover:text-accent-hover"
        >
          View full page
          <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" />
          </svg>
        </a>
      </div>
    </div>
  </div>
</div>

<script>
  import { mountContentModal } from "../modal/controller";

  const modal = document.getElementById("content-modal");
  if (modal instanceof HTMLElement) {
    const cleanup = mountContentModal(modal);
    document.addEventListener("astro:before-preparation", cleanup, { once: true });
  }
</script>
