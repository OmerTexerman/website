---
const projects = [
  {
    title: "Project One",
    description: "A brief description of this project and what problem it solves.",
    tags: ["TypeScript", "React", "Node.js"],
    href: "#",
    repo: "#",
  },
  {
    title: "Project Two",
    description: "A brief description of this project and what problem it solves.",
    tags: ["Go", "PostgreSQL", "Docker"],
    href: "#",
    repo: "#",
  },
  {
    title: "Project Three",
    description: "A brief description of this project and what problem it solves.",
    tags: ["Python", "AWS", "Terraform"],
    href: "#",
    repo: "#",
  },
];
---

<section id="projects" class="py-24 px-6">
  <div class="max-w-5xl mx-auto">
    <h2 class="text-3xl font-bold tracking-tight mb-12">Projects</h2>
    <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-6">
      {projects.map((project) => (
        <div class="group rounded-xl border border-zinc-800 bg-zinc-900/50 p-6 hover:border-zinc-700 hover:bg-zinc-900 transition-all duration-300">
          <div class="flex items-start justify-between mb-3">
            <svg class="w-6 h-6 text-indigo-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 12.75V12A2.25 2.25 0 014.5 9.75h15A2.25 2.25 0 0121.75 12v.75m-8.69-6.44l-2.12-2.12a1.5 1.5 0 00-1.061-.44H4.5A2.25 2.25 0 002.25 6v12a2.25 2.25 0 002.25 2.25h15A2.25 2.25 0 0021.75 18V9a2.25 2.25 0 00-2.25-2.25h-5.379a1.5 1.5 0 01-1.06-.44z" />
            </svg>
            <div class="flex items-center gap-3">
              {project.href !== "#" && (
                <a href={project.href} target="_blank" rel="noopener" class="text-zinc-500 hover:text-white transition-colors" aria-label="Live demo">
                  <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 6H5.25A2.25 2.25 0 003 8.25v10.5A2.25 2.25 0 005.25 21h10.5A2.25 2.25 0 0018 18.75V10.5m-10.5 6L21 3m0 0h-5.25M21 3v5.25" />
                  </svg>
                </a>
              )}
              {project.repo !== "#" && (
                <a href={project.repo} target="_blank" rel="noopener" class="text-zinc-500 hover:text-white transition-colors" aria-label="Source code">
                  <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M12 0C5.374 0 0 5.373 0 12c0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23A11.509 11.509 0 0112 5.803c1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576C20.566 21.797 24 17.3 24 12c0-6.627-5.373-12-12-12z"/></svg>
                </a>
              )}
            </div>
          </div>
          <h3 class="text-lg font-semibold mb-2 group-hover:text-indigo-400 transition-colors">{project.title}</h3>
          <p class="text-sm text-zinc-400 mb-4 leading-relaxed">{project.description}</p>
          <div class="flex flex-wrap gap-2">
            {project.tags.map((tag) => (
              <span class="text-xs text-zinc-500">{tag}</span>
            ))}
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
