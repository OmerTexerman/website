---
import { navItems, site } from "../config";

const pathname = Astro.url.pathname;
---

<header class="fixed inset-x-0 top-0 z-40 border-b border-white/10 bg-dark/72 backdrop-blur-xl">
  <nav class="mx-auto flex h-16 max-w-6xl items-center justify-between gap-4 px-4 sm:px-6">
    <a href="/" class="group flex items-center gap-3" aria-label="Back to desk">
      <span class="inline-flex h-10 w-10 items-center justify-center rounded-2xl border border-white/10 bg-dark-surface-elevated text-sm font-bold font-display text-cream shadow-lg transition-transform group-hover:-translate-y-0.5 group-hover:border-accent/50 group-hover:text-accent">
        {site.initials}
      </span>
      <span class="hidden sm:block">
        <span class="block font-display text-sm font-semibold tracking-tight text-cream">{site.name}</span>
        <span class="block font-mono text-[0.65rem] uppercase tracking-[0.25em] text-muted">Desk navigation</span>
      </span>
    </a>
    <ul class="no-scrollbar flex max-w-[75vw] items-center gap-2 overflow-x-auto whitespace-nowrap rounded-full border border-white/8 bg-white/3 px-2 py-2 sm:max-w-none sm:gap-3">
      {navItems.map(({ href, label }) => (
        <li>
          <a
            href={href}
            aria-current={pathname.startsWith(href) ? "page" : undefined}
            class:list={[
              "inline-flex rounded-full px-3 py-2 font-mono text-xs transition-colors sm:px-4 sm:text-sm",
              pathname.startsWith(href)
                ? "bg-accent/14 text-cream shadow-[0_0_0_1px_rgba(196,69,58,0.28)]"
                : "text-muted hover:text-cream",
            ]}
          >
            {label}
          </a>
        </li>
      ))}
    </ul>
  </nav>
</header>
