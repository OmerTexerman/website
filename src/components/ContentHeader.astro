---
import { orderedSections, site } from "../config";

const pathname = Astro.url.pathname;
---

<header class="fixed top-0 left-0 right-0 z-40 bg-dark/90 backdrop-blur-sm border-b border-white/10">
  <nav class="max-w-6xl mx-auto px-4 sm:px-6 h-14 flex items-center justify-between gap-3">
    <a href="/" class="group flex items-center gap-2" aria-label="Back to desk">
      <span class="inline-flex items-center justify-center w-9 h-9 bg-accent text-white font-display font-bold text-sm rounded-lg transition-transform group-hover:scale-105">
        {site.initials}
      </span>
    </a>
    <ul class="flex items-center gap-3 sm:gap-6 overflow-x-auto whitespace-nowrap no-scrollbar max-w-[75vw] sm:max-w-none">
      {orderedSections.map(({ href, label }) => (
        <li>
          <a
            href={href}
            aria-current={pathname.startsWith(href) ? "page" : undefined}
            class:list={[
              "font-mono text-xs sm:text-sm transition-colors",
              pathname.startsWith(href)
                ? "text-cream font-medium"
                : "text-muted hover:text-cream",
            ]}
          >
            {label}
          </a>
        </li>
      ))}
    </ul>
  </nav>
</header>
