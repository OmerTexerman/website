---
import { getCollection } from "astro:content";

const allBooks = await getCollection("books");
const recentBooks = allBooks
  .filter((b) => b.data.status === "reading" || b.data.status === "finished")
  .slice(0, 5)
  .map((b) => ({ title: b.data.title, spineColor: b.data.spineColor }));
---

<div id="scene-root" class="absolute inset-0" data-books={JSON.stringify(recentBooks)}>
  <canvas id="scene-canvas" class="absolute inset-0 w-full h-full"></canvas>
  <div id="scene-labels" class="absolute inset-0 pointer-events-none overflow-hidden"></div>
</div>
