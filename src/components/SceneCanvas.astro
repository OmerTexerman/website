---
import { getFeaturedShelfBooks, getSpotlight } from "../content/selectors";

const featuredBooks = await getFeaturedShelfBooks();
const spotlight = await getSpotlight();
---

<div id="scene-root" class="absolute inset-0">
  <script type="application/json" data-scene-books set:html={JSON.stringify(featuredBooks)} />
  {spotlight && <script type="application/json" data-scene-spotlight set:html={JSON.stringify(spotlight)} />}
  <canvas
    id="scene-canvas"
    class="absolute inset-0 w-full h-full"
    aria-label="Interactive 3D portfolio scene. Use Tab to move between interactive objects or the skip link for text navigation."
  >
    Your browser does not support the interactive portfolio scene. Use the page navigation links instead.
  </canvas>
  <div id="scene-labels" class="absolute inset-0 pointer-events-none overflow-hidden"></div>
</div>
