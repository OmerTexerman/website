---
import type { PhotoCollection } from "../content/selectors";

interface Props {
	collection: PhotoCollection;
	featured?: boolean;
}

const { collection, featured = false } = Astro.props;
const photoCount = collection.photos.length;
---

<a
  href={`/photos/${collection.id}`}
  class:list={[
    "card-base group block overflow-hidden transition-[transform,box-shadow] duration-200 hover:translate-y-[-2px] hover:ring-2 hover:ring-accent/40",
    featured ? "p-0" : "p-0",
  ]}
>
  <div class="relative overflow-hidden rounded-t-xl">
    <img
      src={collection.cover}
      alt={collection.title}
      loading="lazy"
      class:list={[
        "w-full object-cover transition-transform duration-500 ease-out group-hover:scale-[1.03]",
        featured ? "aspect-[2/1] sm:aspect-[21/9]" : "aspect-[16/10]",
      ]}
    />
  </div>
  <div class="px-4 py-4 sm:px-5">
    <h2 class:list={[
      "font-display font-bold tracking-tight text-cream",
      featured ? "text-2xl sm:text-3xl" : "text-xl",
    ]}>
      {collection.title}
    </h2>
    <div class="mt-1.5 flex items-center gap-2 font-mono text-xs tracking-wide text-muted">
      {collection.location && <span>{collection.location}</span>}
      {collection.location && collection.date && <span class="text-muted/40">/</span>}
      {collection.date && <span>{collection.date}</span>}
      <span class="text-muted/40">/</span>
      <span>{photoCount} photo{photoCount !== 1 ? "s" : ""}</span>
    </div>
    {featured && collection.description && (
      <p class="mt-3 text-sm leading-relaxed text-cream-dark line-clamp-2">
        {collection.description}
      </p>
    )}
  </div>
</a>
