---
import type { PhotoCollection } from "../content/selectors";
import { cloudinaryUrl } from "../image";

interface Props {
	collection: PhotoCollection;
	featured?: boolean;
}

const { collection, featured = false } = Astro.props;
const photoCount = collection.photos.length;
const coverTransforms = featured ? "f_auto,q_auto,w_800" : "f_auto,q_auto,w_600";
---

<a href={`/photos/${collection.id}`} class:list={["pinned-photo group", featured && "pinned-photo-featured"]}>
  {/* Push pin */}
  <div class="push-pin" aria-hidden="true"></div>

  {/* Photo with white border */}
  <div class="pinned-photo-frame">
    <img
      src={cloudinaryUrl(collection.cover, coverTransforms)}
      alt={collection.title}
      loading="lazy"
      decoding="async"
      width="600"
      height="400"
      class:list={[
        "pinned-photo-img",
        featured ? "aspect-[3/2]" : "aspect-[4/3]",
      ]}
    />
  </div>

  {/* Caption area (in the white border) */}
  <div class="pinned-photo-caption">
    <h2 class:list={[
      "pinned-photo-title",
      featured ? "text-lg" : "text-sm",
    ]}>
      {collection.title}
    </h2>
    <div class="pinned-photo-meta">
      {collection.location && <span>{collection.location}</span>}
      {collection.location && collection.date && <span>/</span>}
      {collection.date && <span>{collection.date}</span>}
      <span>/</span>
      <span>{photoCount} photo{photoCount !== 1 ? "s" : ""}</span>
    </div>
  </div>
</a>
