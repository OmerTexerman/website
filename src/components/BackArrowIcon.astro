---
interface Props {
	class?: string;
}

const className = Astro.props.class;
const classes = ["w-4", "h-4", ...(className ? className.split(" ") : [])].join(" ");
---

<svg class={classes} fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
  <path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7" />
</svg>
