---
import { getEntry } from "astro:content";

interface Props {
	slug: string;
	class?: string;
}

const { slug, class: className } = Astro.props;
const post = await getEntry("blog", slug);
const visible = post && !post.data.draft;
---

{visible && (
  <a
    href={`/blog/${post.id}`}
    class:list={[
      "inline-flex items-center gap-1.5 font-mono text-xs text-accent transition-colors hover:text-accent-hover",
      className,
    ]}
  >
    <svg class="h-3.5 w-3.5 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
      <path stroke-linecap="round" stroke-linejoin="round" d="M13.19 8.688a4.5 4.5 0 011.242 7.244l-4.5 4.5a4.5 4.5 0 01-6.364-6.364l1.757-1.757m9.86-2.54a4.5 4.5 0 00-1.242-7.244l-4.5-4.5a4.5 4.5 0 00-6.364 6.364L4.34 8.798" />
    </svg>
    I wrote about this
  </a>
)}
