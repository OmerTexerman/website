---
interface Props {
	title: string;
	author: string;
	spineColor: string;
	url?: string;
	pulled?: boolean;
}

const { title, author, spineColor, url, pulled = false } = Astro.props;
---

{url ? (
  <a
    href={url}
    target="_blank"
    rel="noopener noreferrer"
    class="shelf-book"
    style={`background-color: ${spineColor}`}
    data-pulled={pulled ? "true" : undefined}
    aria-label={`${title} by ${author}`}
  >
    <span class="shelf-book__author">{author}</span>
    <span class="shelf-book__label">{title}</span>
  </a>
) : (
  <div class="shelf-book" style={`background-color: ${spineColor}`} data-pulled={pulled ? "true" : undefined}>
    <span class="shelf-book__author">{author}</span>
    <span class="shelf-book__label">{title}</span>
  </div>
)}
