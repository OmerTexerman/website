---
interface Props {
	id: string;
	title: string;
	author: string;
	spineColor: string;
	url?: string;
	pulled?: boolean;
}

const { id, title, author, spineColor, url, pulled = false } = Astro.props;
const coverTone = `color-mix(in srgb, ${spineColor} 82%, white 18%)`;
---

<button
  type="button"
  class="shelf-book"
  style={`--book-spine:${spineColor}; --book-cover:${coverTone};`}
  data-book-id={id}
  data-book-title={title}
  data-book-author={author}
  data-book-color={spineColor}
  data-book-url={url}
  data-pulled={pulled ? "true" : undefined}
  aria-label={`Preview ${title} by ${author}`}
>
  <span class="shelf-book__object" aria-hidden="true">
    <span class="shelf-book__spine">
      <span class="shelf-book__label">{title}</span>
    </span>
    <span class="shelf-book__front"></span>
    <span class="shelf-book__pages"></span>
  </span>
</button>
