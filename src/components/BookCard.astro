---
import RelatedPost from "./RelatedPost.astro";

interface Props {
	title: string;
	author: string;
	spineColor: string;
	cover?: string;
	url?: string;
	post?: string;
	size?: "hero" | "shelf" | "compact";
}

const { title, author, spineColor, cover, url, post, size = "shelf" } = Astro.props;

const Tag = url ? "a" : "div";
const linkProps = url ? { href: url, target: "_blank", rel: "noopener noreferrer" } : {};
---

<Tag
  {...linkProps}
  class:list={[
    "book-card group",
    `book-card-${size}`,
    url && "cursor-pointer",
  ]}
>
  {/* The physical book — cover + spine edge */}
  <div class="book-physical">
    <div class="book-spine-edge" style={`background-color: ${spineColor}`}></div>
    <div class="book-cover">
      {cover ? (
        <img
          src={cover}
          alt={`Cover of ${title}`}
          loading="lazy"
          width="200"
          height="300"
          class="book-cover-img"
        />
      ) : (
        <div class="book-placeholder" style={`background-color: ${spineColor}`}>
          <span class="book-placeholder-title">{title}</span>
          <span class="book-placeholder-author">{author}</span>
        </div>
      )}
    </div>
  </div>
  {/* Book shadow on the shelf */}
  <div class="book-shadow"></div>
  {size !== "hero" && (
    <div class="book-info">
      <p class="book-title">{title}</p>
      <p class="book-author">{author}</p>
      {post && (
        <div class="mt-1.5">
          <RelatedPost slug={post} />
        </div>
      )}
    </div>
  )}
</Tag>
