---
interface Props {
	title: string;
	author: string;
	spineColor: string;
	url?: string;
}

const { title, author, spineColor, url } = Astro.props;
---

<div class="group flex items-stretch rounded-xl border border-white/8 bg-dark-surface-elevated overflow-hidden transition-[transform,box-shadow] duration-200 hover:ring-2 hover:ring-accent/40 hover:translate-y-[-1px]">
  <div class="w-2 shrink-0 transition-all duration-200 group-hover:w-2.5" style={`background-color: ${spineColor}`}></div>
  <div class="flex items-center gap-4 p-4 flex-1 min-w-0">
    <div class="flex-1 min-w-0">
      {url ? (
        <a href={url} target="_blank" rel="noopener noreferrer" class="font-display text-lg font-bold text-cream hover:text-accent transition-colors block truncate">
          {title}
          <svg class="inline w-3.5 h-3.5 ml-1.5 opacity-0 group-hover:opacity-60 transition-opacity" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M7 17L17 7M17 7H7M17 7v10" />
          </svg>
        </a>
      ) : (
        <p class="font-display text-lg font-bold text-cream truncate">{title}</p>
      )}
      <p class="text-cream-dark text-sm mt-0.5">{author}</p>
    </div>
  </div>
</div>
