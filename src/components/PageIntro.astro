---
interface Props {
	title: string;
	description?: string;
	delay?: number;
}

const { title, description, delay = 0 } = Astro.props;
const shortTitle = title.toLowerCase();
---

<div class="mb-12 border-b border-white/10 pb-8 sm:pb-10" data-animate style={`transition-delay: ${delay}s`}>
	<div class="page-kicker mb-5">Desk view / {shortTitle}</div>
	<div class="page-intro-grid">
		<div>
			<h1 class="font-display text-4xl font-bold tracking-tight text-cream sm:text-5xl lg:text-6xl">{title}</h1>
			{description && <p class="mt-4 max-w-2xl text-base leading-relaxed text-cream-dark sm:text-lg">{description}</p>}
		</div>
		<aside class="page-note">
			<p class="section-label mb-3">From the room</p>
			<p class="text-sm leading-relaxed text-cream-dark sm:text-[0.95rem]">
				Same apartment, different object: less dashboard, more artifact. Each section should feel like you found a different thing on or near the desk.
			</p>
		</aside>
	</div>
</div>
