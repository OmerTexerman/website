---
interface Props {
	title: string;
	description?: string;
	delay?: number;
}

const { title, description, delay = 0 } = Astro.props;
---

<div class="mb-12" data-animate style={`transition-delay: ${delay}s`}>
	<div class="flex items-center gap-3 mb-4">
		<div class="w-8 h-[3px] bg-accent rounded-full"></div>
		<span class="font-mono text-xs uppercase tracking-[0.2em] text-accent">
			{title}
		</span>
	</div>
	<h1 class="font-display text-4xl sm:text-5xl font-bold tracking-tight mb-3 text-cream">
		{title}
	</h1>
	{description && <p class="text-cream-dark text-lg leading-relaxed max-w-2xl">{description}</p>}
</div>
