---
import type { PhotoGalleryPhoto } from "../dom/photo-gallery";
import { cloudinaryUrl } from "../image";
import { safeJson } from "../utils";

interface Props {
	photos: PhotoGalleryPhoto[];
}

const { photos } = Astro.props;

/** Lightbox gets larger, format-optimised images. */
const lightboxPhotos = photos.map((p) => ({
	...p,
	src: cloudinaryUrl(p.src, "f_auto,q_auto,w_1600"),
}));
---

<div data-photo-gallery>
  <script is:inline type="application/json" data-photo-gallery-data set:html={safeJson(lightboxPhotos)} />

  <!-- Masonry Grid -->
  <div class="photo-masonry">
    {photos.map((photo, i) => (
      <button
        type="button"
        class="photo-masonry-item group"
        data-photo-index={i}
        aria-label={`View photo: ${photo.alt}`}
      >
        <img
          src={cloudinaryUrl(photo.src, "f_auto,q_auto,w_600")}
          alt={photo.alt}
          loading="lazy"
          decoding="async"
          width="600"
          height="400"
          class="photo-masonry-img"
        />
        {photo.caption && (
          <div class="photo-masonry-overlay">
            <p class="photo-masonry-caption">{photo.caption}</p>
          </div>
        )}
      </button>
    ))}
  </div>

  <!-- Lightbox -->
  <dialog
    data-photo-lightbox
    class="photo-lightbox"
    aria-label="Photo viewer"
  >
    <!-- Close -->
    <button
      data-photo-lightbox-close
      class="photo-lightbox-close"
      aria-label="Close lightbox"
    >
      <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
        <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
      </svg>
    </button>

    <!-- Previous -->
    <button
      data-photo-lightbox-prev
      class="photo-lightbox-nav photo-lightbox-prev"
      aria-label="Previous photo"
    >
      <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
        <path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7" />
      </svg>
    </button>

    <!-- Next -->
    <button
      data-photo-lightbox-next
      class="photo-lightbox-nav photo-lightbox-next"
      aria-label="Next photo"
    >
      <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
        <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" />
      </svg>
    </button>

    <!-- Image -->
    <div class="photo-lightbox-content">
      <img
        data-photo-lightbox-img
        src=""
        alt=""
        decoding="async"
        class="photo-lightbox-image"
      />
    </div>

    <!-- Info -->
    <div class="photo-lightbox-info" aria-live="polite">
      <p data-photo-lightbox-caption class="photo-lightbox-info-caption"></p>
      <span data-photo-lightbox-counter class="photo-lightbox-info-counter font-mono"></span>
    </div>
  </dialog>
</div>

<script>
  import { mountPhotoGalleries } from "../dom/photo-gallery";

  const cleanup = mountPhotoGalleries();
  document.addEventListener("astro:before-preparation", cleanup, { once: true });
  window.addEventListener("pagehide", cleanup, { once: true });
</script>
