---
import type { PhotoGalleryPhoto } from "../dom/photo-gallery";

interface Props {
	photos: PhotoGalleryPhoto[];
}

const { photos } = Astro.props;
---

<div data-photo-gallery>
  <template data-photo-gallery-data>{JSON.stringify(photos)}</template>

  <div class="grid grid-cols-1 gap-4 sm:grid-cols-2 lg:grid-cols-3">
    {photos.map((photo, i) => (
      <button
        type="button"
        class="group relative aspect-[4/3] cursor-pointer overflow-hidden rounded-xl border border-white/8 bg-dark-surface-elevated focus:outline-none focus:ring-2 focus:ring-accent"
        data-photo-index={i}
        aria-label={`View photo: ${photo.alt}`}
      >
        <img
          src={photo.src}
          alt={photo.alt}
          loading="lazy"
          class="h-full w-full object-cover transition-transform duration-300 group-hover:scale-105"
        />
        {photo.caption && (
          <div class="absolute inset-x-0 bottom-0 translate-y-full bg-gradient-to-t from-black/70 to-transparent p-3 transition-transform duration-300 group-hover:translate-y-0 group-focus-visible:translate-y-0">
            <p class="text-sm text-cream">{photo.caption}</p>
          </div>
        )}
      </button>
    ))}
  </div>

  <dialog
    data-photo-lightbox
    class="fixed inset-0 z-50 m-0 h-full max-h-none w-full max-w-none bg-dark/95 p-0 backdrop-blur-sm"
  >
    <div class="flex h-full w-full items-center justify-center p-8">
      <button
        data-photo-lightbox-close
        class="absolute right-4 top-4 z-10 text-3xl font-light text-cream/80 hover:text-cream"
        aria-label="Close lightbox"
      >
        &times;
      </button>
      <img
        data-photo-lightbox-img
        src=""
        alt=""
        class="max-h-full max-w-full rounded-lg object-contain"
      />
      <p
        data-photo-lightbox-caption
        class="absolute bottom-8 left-1/2 -translate-x-1/2 text-center text-base text-cream"
      >
      </p>
    </div>
  </dialog>
</div>

<script>
  import { mountPhotoGalleries } from "../dom/photo-gallery";

  const cleanup = mountPhotoGalleries();
  document.addEventListener("astro:before-preparation", cleanup, { once: true });
</script>
