---
import Tag from "./Tag.astro";

interface Props {
	title: string;
	description: string;
	tech: string[];
	url?: string;
	repo?: string;
}

const { title, description, tech, url, repo } = Astro.props;
---

<div class="card-base card-base-lg card-hover">
  <h3 class="card-title mb-2">{title}</h3>
  <p class="card-desc mb-4">{description}</p>
  <div class="card-tags mb-4">
    {tech.map((t) => (
      <Tag label={t} />
    ))}
  </div>
  <div class="flex gap-4">
    {url && (
      <a href={url} target="_blank" rel="noopener noreferrer" class="font-mono text-sm text-accent hover:text-accent-hover transition-colors">
        Live site &rarr;
      </a>
    )}
    {repo && (
      <a href={repo} target="_blank" rel="noopener noreferrer" class="font-mono text-sm text-muted hover:text-cream transition-colors">
        Source code
      </a>
    )}
  </div>
</div>
