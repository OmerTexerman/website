---
import Tag from "./Tag.astro";

interface Props {
	title: string;
	description: string;
	tech: string[];
	url?: string;
	repo?: string;
}

const { title, description, tech, url, repo } = Astro.props;
---

<div class="content-card p-5 sm:p-6">
  <div class="mb-4 flex flex-wrap items-center justify-between gap-3">
    <p class="section-label">Project spotlight</p>
    <div class="flex h-2.5 w-16 overflow-hidden rounded-full bg-white/8">
      <span class="h-full w-1/3 bg-accent/65"></span>
    </div>
  </div>
  <h3 class="font-display text-xl font-bold text-cream sm:text-2xl">{title}</h3>
  <p class="mt-3 text-sm leading-relaxed text-cream-dark sm:text-base">{description}</p>
  <div class="mt-5 flex flex-wrap gap-2">
    {tech.map((t) => (
      <Tag label={t} />
    ))}
  </div>
  <div class="mt-6 flex flex-wrap gap-3">
    {url && (
      <a href={url} target="_blank" rel="noopener noreferrer" class="desk-link">
        Live site <span aria-hidden="true">&rarr;</span>
      </a>
    )}
    {repo && (
      <a href={repo} target="_blank" rel="noopener noreferrer" class="desk-link text-muted hover:text-cream">
        Source code
      </a>
    )}
  </div>
</div>
