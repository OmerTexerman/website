---
import RelatedPost from "./RelatedPost.astro";

interface Props {
	title: string;
	description: string;
	tech: string[];
	image?: string;
	url?: string;
	repo?: string;
	post?: string;
}

const { title, description, tech, image, url, repo, post } = Astro.props;
---

<div class="project-window">
  {/* Title bar — macOS-style window chrome */}
  <div class="project-titlebar">
    <div class="project-dots">
      <span class="project-dot project-dot-red"></span>
      <span class="project-dot project-dot-yellow"></span>
      <span class="project-dot project-dot-green"></span>
    </div>
    <span class="project-titlebar-text">{title}</span>
  </div>

  {/* Window body */}
  <div class="project-body">
    {image && (
      <div class="project-image">
        <img src={image} alt={`Screenshot of ${title}`} loading="lazy" />
      </div>
    )}
    <p class="project-desc">{description}</p>
    <span class="project-tech">{tech.join(" · ")}</span>
    <div class="project-links">
      {url && (
        <a href={url} target="_blank" rel="noopener noreferrer" class="project-link project-link-primary">
          → live site
        </a>
      )}
      {repo && (
        <a href={repo} target="_blank" rel="noopener noreferrer" class="project-link">
          → source
        </a>
      )}
      {post && <RelatedPost slug={post} />}
    </div>
  </div>
</div>
