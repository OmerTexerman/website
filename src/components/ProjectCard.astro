---
import RelatedPost from "./RelatedPost.astro";

interface Props {
	title: string;
	description: string;
	tech: string[];
	image?: string;
	url?: string;
	repo?: string;
	post?: string;
}

const { title, description, tech, image, url, repo, post } = Astro.props;
---

<div class="wm-project-entry">
  <div class="wm-project-header">
    <span class="wm-project-name">{title}</span>
    <span class="wm-project-tech">{tech.join(" · ")}</span>
  </div>
  {image && (
    <div class="wm-project-image">
      <img src={image} alt={`Screenshot of ${title}`} loading="lazy" width="600" height="400" />
    </div>
  )}
  <p class="wm-project-desc">{description}</p>
  <div class="wm-project-links">
    {url && (
      <a href={url} target="_blank" rel="noopener noreferrer" class="wm-project-link" aria-label={`View live: ${title}`}>
        <span class="wm-link-icon">↗</span> live
      </a>
    )}
    {repo && (
      <a href={repo} target="_blank" rel="noopener noreferrer" class="wm-project-link" aria-label={`View source: ${title}`}>
        <span class="wm-link-icon">⎇</span> src
      </a>
    )}
    {post && <RelatedPost slug={post} />}
  </div>
</div>
