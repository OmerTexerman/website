---
interface Props {
  title: string;
  description: string;
  tech: string[];
  url?: string;
  repo?: string;
}

const { title, description, tech, url, repo } = Astro.props;
---

<div class="bg-cream rounded-xl p-6 transition-all hover:ring-2 hover:ring-accent/40 hover:translate-y-[-2px]">
  <h3 class="font-display text-xl font-bold text-dark mb-2">{title}</h3>
  <p class="text-muted text-sm leading-relaxed mb-4">{description}</p>
  <div class="flex flex-wrap gap-2 mb-4">
    {tech.map((t) => (
      <span class="font-mono text-xs px-2 py-0.5 rounded-full bg-accent/10 text-accent border border-accent/20">
        {t}
      </span>
    ))}
  </div>
  <div class="flex gap-4">
    {url && (
      <a href={url} target="_blank" rel="noopener" class="font-mono text-sm text-accent hover:text-accent-hover transition-colors">
        Live site &rarr;
      </a>
    )}
    {repo && (
      <a href={repo} target="_blank" rel="noopener" class="font-mono text-sm text-muted hover:text-dark transition-colors">
        Source code
      </a>
    )}
  </div>
</div>
