---
import Tag from "./Tag.astro";

interface RelatedPost {
	slug: string;
	title: string;
}

interface Props {
	title: string;
	description: string;
	tech: string[];
	folder?: string;
	notes?: string[];
	relatedPosts?: RelatedPost[];
	url?: string;
	repo?: string;
}

const {
	title,
	description,
	tech,
	folder = "Desk Folder",
	notes = [],
	relatedPosts = [],
	url,
	repo,
} = Astro.props;
---

<div class="folder-card">
  <div class="folder-card__tab">{folder}</div>
  <div class="folder-card__body">
    <div class="folio-meta">
      <p class="section-label">Project folder</p>
      <p class="font-mono text-xs uppercase tracking-[0.2em] text-muted-light">{tech.length} tools noted</p>
    </div>

    <div class="folio-body">
      <h3 class="font-display text-2xl font-bold tracking-tight text-cream sm:text-3xl">{title}</h3>
      <p class="max-w-2xl text-sm leading-relaxed text-cream-dark sm:text-base">{description}</p>
      <div class="tag-cluster">
        {tech.map((t) => (
          <Tag label={t} />
        ))}
      </div>
      {notes.length > 0 && (
        <ul class="folder-card__notes">
          {notes.map((note) => (
            <li>{note}</li>
          ))}
        </ul>
      )}
    </div>

    <div class="folio-aside">
      <p class="section-label mb-3">Attached</p>
      {relatedPosts.length > 0 ? (
        <div class="folder-card__attachments">
          {relatedPosts.map((post) => (
            <a href={`/blog/${post.slug}`} class="attachment-chip">
              <span class="attachment-chip__dot"></span>
              {post.title}
            </a>
          ))}
        </div>
      ) : (
        <p class="text-sm text-muted">No linked notes yet.</p>
      )}

      <div class="mt-5 flex flex-wrap gap-3">
        {url && (
          <a href={url} target="_blank" rel="noopener noreferrer" class="desk-link">
            Open live site <span aria-hidden="true">&rarr;</span>
          </a>
        )}
        {repo && (
          <a href={repo} target="_blank" rel="noopener noreferrer" class="desk-link text-muted hover:text-cream">
            View source
          </a>
        )}
      </div>
    </div>
  </div>
</div>
