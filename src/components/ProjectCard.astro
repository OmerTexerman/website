---
import Tag from "./Tag.astro";

interface Props {
	title: string;
	description: string;
	tech: string[];
	url?: string;
	repo?: string;
}

const { title, description, tech, url, repo } = Astro.props;
---

<div class="rounded-xl border border-white/8 bg-dark-surface-elevated p-4 sm:p-6 transition-[transform,box-shadow] duration-200 hover:ring-2 hover:ring-accent/40 hover:translate-y-[-2px]">
  <h3 class="font-display text-xl font-bold text-cream mb-2">{title}</h3>
  <p class="text-cream-dark text-sm leading-relaxed mb-4">{description}</p>
  <div class="flex flex-wrap gap-2 mb-4">
    {tech.map((t) => (
      <Tag label={t} />
    ))}
  </div>
  <div class="flex gap-4">
    {url && (
      <a href={url} target="_blank" rel="noopener noreferrer" class="font-mono text-sm text-accent hover:text-accent-hover transition-colors">
        Live site &rarr;
      </a>
    )}
    {repo && (
      <a href={repo} target="_blank" rel="noopener noreferrer" class="font-mono text-sm text-muted hover:text-cream transition-colors">
        Source code
      </a>
    )}
  </div>
</div>
