---
const pathname = Astro.url.pathname;

const links = [
  { href: "/", label: "Home" },
  { href: "/blog", label: "Blog" },
  { href: "/#projects", label: "Projects" },
  { href: "/#contact", label: "Contact" },
];
---

<header class="fixed top-0 left-0 right-0 z-50 bg-cream/90 backdrop-blur-sm border-b-2 border-ink">
  <nav class="max-w-6xl mx-auto px-6 h-16 flex items-center justify-between">
    <a href="/" class="group flex items-center gap-2">
      <span class="inline-flex items-center justify-center w-10 h-10 bg-coral text-white font-display font-bold text-sm rounded-lg border-2 border-ink hard-shadow-sm group-hover:translate-x-[-1px] group-hover:translate-y-[-1px] group-hover:shadow-[4px_4px_0_var(--color-ink)] transition-all">
        OT
      </span>
    </a>
    <ul class="flex items-center gap-6 sm:gap-8">
      {links.map(({ href, label }) => (
        <li>
          <a
            href={href}
            class:list={[
              "font-mono text-sm relative py-1 transition-colors",
              pathname === href
                ? "text-ink font-bold"
                : "text-muted hover:text-ink",
            ]}
          >
            {label}
            {pathname === href && (
              <span class="absolute -bottom-0.5 left-0 right-0 h-[2px] bg-coral" />
            )}
          </a>
        </li>
      ))}
    </ul>
  </nav>
</header>
