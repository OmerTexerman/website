---
const pathname = Astro.url.pathname;

const links = [
  { href: "/", label: "Home" },
  { href: "/blog", label: "Blog" },
  { href: "/#projects", label: "Projects" },
  { href: "/#contact", label: "Contact" },
];
---

<header class="fixed top-0 left-0 right-0 z-50 border-b border-zinc-800/50 bg-zinc-950/80 backdrop-blur-md">
  <nav class="max-w-5xl mx-auto px-6 h-16 flex items-center justify-between">
    <a href="/" class="text-lg font-semibold tracking-tight hover:text-indigo-400 transition-colors">
      portfolio
    </a>
    <ul class="flex items-center gap-8">
      {links.map(({ href, label }) => (
        <li>
          <a
            href={href}
            class:list={[
              "text-sm transition-colors",
              pathname === href
                ? "text-white"
                : "text-zinc-400 hover:text-white",
            ]}
          >
            {label}
          </a>
        </li>
      ))}
    </ul>
  </nav>
</header>
