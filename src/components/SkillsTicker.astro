---
const skills = [
  "TypeScript",
  "React",
  "Node.js",
  "Go",
  "PostgreSQL",
  "Docker",
  "AWS",
  "Kubernetes",
  "Next.js",
  "Linux",
];

const doubled = [...skills, ...skills];
---

<div class="border-y-2 border-ink bg-yellow overflow-hidden select-none">
  <div class="flex animate-marquee py-4">
    {doubled.map((skill) => (
      <span class="font-mono text-sm font-bold text-ink shrink-0 flex items-center gap-6 px-6">
        {skill}
        <span class="text-coral text-base">&#10022;</span>
      </span>
    ))}
  </div>
</div>
