---
import { site } from "../config";
import { safeJson } from "../utils";

interface Props {
	title: string;
	description: string;
	image?: string;
	type?: "website" | "article";
	publishedDate?: Date;
	noindex?: boolean;
}

const { title, description, image, type = "website", publishedDate, noindex = false } = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, Astro.site);
/** Default PNG so Open Graph / Twitter get a raster image (SVG is not reliably supported). */
const resolvedImage = image || "/og-default.png";
const ogImageURL = new URL(resolvedImage, Astro.site);
const isHomepage = Astro.url.pathname === "/";
const jsonLdType = type === "article" ? "BlogPosting" : isHomepage ? "WebSite" : "WebPage";
const twitterCard = "summary_large_image";
---

<link rel="canonical" href={canonicalURL} />

{noindex && <meta name="robots" content="noindex" />}

<!-- Open Graph -->
<meta property="og:type" content={type} />
<meta property="og:url" content={canonicalURL} />
<meta property="og:title" content={title} />
<meta property="og:description" content={description} />
<meta property="og:image" content={ogImageURL} />
<meta property="og:site_name" content={site.name} />
<meta property="og:locale" content="en_US" />

<!-- Twitter -->
<meta name="twitter:card" content={twitterCard} />
<meta name="twitter:title" content={title} />
<meta name="twitter:description" content={description} />
<meta name="twitter:image" content={ogImageURL} />

{publishedDate && (
  <meta property="article:published_time" content={publishedDate.toISOString()} />
)}

<!-- JSON-LD (omit on noindex pages e.g. 404) -->
{!noindex && (
  <script is:inline type="application/ld+json" set:html={safeJson({
    "@context": "https://schema.org",
    "@type": jsonLdType,
    name: title,
    description,
    url: canonicalURL.href,
    image: ogImageURL.href,
    ...(type === "article" && publishedDate ? { datePublished: publishedDate.toISOString() } : {}),
    author: {
      "@type": "Person",
      name: site.name,
    },
  })} />
)}
