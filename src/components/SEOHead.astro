---
import { site } from "../config";

interface Props {
	title: string;
	description: string;
	image?: string;
	type?: "website" | "article";
	publishedDate?: Date;
}

const { title, description, image, type = "website", publishedDate } = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, Astro.site);
const ogImageURL = image ? new URL(image, Astro.site) : null;
---

<link rel="canonical" href={canonicalURL} />

<!-- Open Graph -->
<meta property="og:type" content={type} />
<meta property="og:url" content={canonicalURL} />
<meta property="og:title" content={title} />
<meta property="og:description" content={description} />
{ogImageURL && <meta property="og:image" content={ogImageURL} />}
<meta property="og:site_name" content={site.name} />

<!-- Twitter -->
<meta name="twitter:card" content="summary_large_image" />
<meta name="twitter:title" content={title} />
<meta name="twitter:description" content={description} />
{ogImageURL && <meta name="twitter:image" content={ogImageURL} />}

{publishedDate && (
  <meta property="article:published_time" content={publishedDate.toISOString()} />
)}

<!-- JSON-LD -->
<script is:inline type="application/ld+json" set:html={JSON.stringify({
  "@context": "https://schema.org",
  "@type": type === "article" ? "BlogPosting" : "WebSite",
  name: title,
  description,
  url: canonicalURL.href,
  ...(type === "article" && publishedDate ? { datePublished: publishedDate.toISOString() } : {}),
  author: {
    "@type": "Person",
    name: site.name,
  },
})} />
